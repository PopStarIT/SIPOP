<?php if ( ! defined('BASEPATH')) exit('No direct script access allowed');Class Report_barang_jadi extends CI_Controller { 	function __construct(){ 		parent::__construct(); 				$this->data_request = $_REQUEST;				$module = $this->router->module;		$directory = $this->router->directory;		$class = $this->router->class;		$method = $this->router->method;		$directory = trim(str_replace('../modules/'.$module ,'',str_replace('/controllers/','',$directory)),'/');				$this->module = $module;		if(trim($directory) != ''){			$this->directory = $directory;		} else {			$this->directory = '0';			$this->directory2 = '';		}		$this->class = $class;		$this->method = $method;	}		function penerimaan_barang_jadi_table_awal(){		$field = array();		$field['r1'] = array('sc' => 'r1','ctype' => 'text', 'bypassvalue' => '', 'title' => 'NO PENERIMAAN');		$field['r2'] = array('sc' => 'r2','ctype' => 'text', 'bypassvalue' => '', 'title' => 'TGL PENERIMAAN');		$field['r3'] = array('sc' => 'r3','ctype' => 'text', 'bypassvalue' => '', 'title' => 'QUANTITY');		$field['r4'] = array('sc' => 'r4','ctype' => 'text', 'bypassvalue' => '', 'title' => 'KODE FG');		$field['r5'] = array('sc' => 'r5','ctype' => 'text', 'bypassvalue' => '', 'title' => 'NAMA FG');		$field['r6'] = array('sc' => 'r6','ctype' => 'int', 'bypassvalue' => '', 'title' => 'JUMLAH', 'data_type' => 'decimal', 'decimal_digit' => 4);		$field['r7'] = array('sc' => 'r7','ctype' => 'text', 'bypassvalue' => '', 'title' => 'SAT');				return $field;	}		function penerimaan_barang_jadi_table(){				$field = array();		$field['r1'] = array('sc' => 'r1','ctype' => 'text', 'bypassvalue' => '', 'title' => 'KODE');		$field['r2'] = array('sc' => 'r2','ctype' => 'text', 'bypassvalue' => '', 'title' => 'NAMA BARANG');		$field['r3'] = array('sc' => 'r3','ctype' => 'text', 'bypassvalue' => '', 'title' => 'SATUAN');		$field['r10'] = array('sc' => 'r10','ctype' => 'text', 'bypassvalue' => '', 'title' => 'QUANTITY','data_type' => 'decimal', 'decimal_digit' => 4);		$field['r11'] = array('sc' => 'r11','ctype' => 'int', 'bypassvalue' => '', 'title' => 'AMOUNT', 'data_type' => 'decimal', 'decimal_digit' => 4);				//,'QTY SALDO AWAL'		//		,'AMOUNT SALDO AWAL'		//		,'QTY PEMASUKAN'		//		,'AMOUNT PEMASUKAN'		//		,'QTY PENGELUARAN'		//		,'AMOUNT PENGELUARAN'		//$field['r5'] = array('sc' => 'r5','ctype' => 'text', 'bypassvalue' => '', 'title' => 'QUANTITY','data_type' => 'decimal', 'decimal_digit' => 4);		//$field['r6'] = array('sc' => 'r7','ctype' => 'text', 'bypassvalue' => '', 'title' => 'VALAS');		//$field['r7'] = array('sc' => 'r7','ctype' => 'text', 'bypassvalue' => '', 'title' => 'UNIT PRICE');		//$field['r8'] = array('sc' => 'r6','ctype' => 'int', 'bypassvalue' => '', 'title' => 'TOTAL', 'data_type' => 'decimal', 'decimal_digit' => 4);					return $field;	}		function index_asli(){		$this->load->model('main');		$component['loadlayout'] = true;		$component['view_load'] = 'accounting_report/report_barang_jadi/view';		$component['load_js'][] = 'accounting_report/report_barang_jadi/view';				$component['page_title'] = "Report Barang Jadi";		$dashboard_table = array();	     	   // $field = $this->purchase_order_table();		$field = $this->penerimaan_barang_jadi_table();				$dashboard_table['field'] = $field;		//var_dump($dashboard_table);		$component['dashboard_table'] = $dashboard_table;				$this->authentication->ajaxlayout($component);	}		function rpt_barang_jadi_table() {		$view = 'view_purchase_order';		$get_field = $this->ecc_library->get_field($view);				$get_field['r1']['hidden'] = true;		// $get_field['r13']['hidden'] = true;		$get_field['r14']['hidden'] = true;		$get_field['r15']['hidden'] = true;		$get_field['r16']['hidden'] = true;		$get_field['r17']['hidden'] = true;		$get_field['r18']['hidden'] = true;		$get_field['r19']['hidden'] = true;		$get_field['r20']['hidden'] = true;		$get_field['r21']['hidden'] = true;		$get_field['r22']['hidden'] = true;		$get_field['r23']['hidden'] = true;		$get_field['r24']['hidden'] = true;		$get_field['r25']['hidden'] = true;		$get_field['r26']['hidden'] = true;		$get_field['r27']['hidden'] = true;		$get_field['r28']['hidden'] = true;		$get_field['r29']['hidden'] = true;		$get_field['r30']['hidden'] = true;      		$get_field['r2']['width'] = 200;      // $get_field['r3']['width'] = 170;      // $get_field['r4']['width'] = 170;      // $get_field['r5']['width'] = 170;      // $get_field['r6']['width'] = 210;      // $get_field['r9']['width'] = 170;				return $get_field;	}		function index(){		$this->load->model('main');		$component['loadlayout'] = true;		$component['view_load'] = 'accounting_report/report_barang_jadi/view';		$component['load_js'][] = 'accounting_report/report_barang_jadi/view';				$component['page_title'] = "Report Barang Jadi";		$dashboard_table = array();	     	  // $field = $this->rpt_barang_jadi_table();		$field = $this->penerimaan_barang_jadi_table();				$dashboard_table['field'] = $field;		//var_dump($dashboard_table);		$component['dashboard_table'] = $dashboard_table;				$this->authentication->ajaxlayout($component);	}		function loaddata(){		//var_dump("loooooad");die();		//print_r("cccc");				$field = $this->penerimaan_barang_jadi_table();				$date_start = isset($_REQUEST['date_start']) ?  $_REQUEST['date_start'] : '';		$date_end = isset($_REQUEST['date_end']) ? $_REQUEST['date_end'] : '';		$print = isset($_REQUEST['print']) ? $_REQUEST['print'] : 0;		$format = isset($_REQUEST['format']) ? $_REQUEST['format'] : 'xlsx';		$page = isset($_POST['page'])?$_POST['page']:1; // get the requested page         $rows = isset($_POST['rows'])?$_POST['rows']:10; // get how many rows we want to have into the grid         $sidx = isset($_POST['sidx'])?$_POST['sidx']:'r1'; // get index row - i.e. user click to sort         $sord = isset($_POST['sord'])?$_POST['sord']:'0'; // get the direction 		$search = isset($_REQUEST['_search'])?$_REQUEST['_search']:false; 		$filterRules =  isset($_POST['filters'])?$_POST['filters']:false;		//var_dump($format);die();				$limit =  $rows;		$offset =  $rows * ($page - 1);						$order = isset($_REQUEST['order']) ? $_REQUEST['order'] : array();				if($sord == 'asc'){			$sord = 1;		} else {			$sord = 2;		}				$sort =	$sidx. '='.$sord;							if(strlen(trim($date_start)) == 0 ){			$date_start = '1900-01-01';		}				if(strlen(trim($date_end)) == 0 ){			$date_end = '9999-12-31';		}				$return = array();		$return['valid'] = false;		$return['message'] = "Internal Server Error";			//var_dump($print);die();								//$sp = "dbo.sp_rpt_bc_out_old";			//sp_rpt_barang_jadi_accounting        $sp = "dbo.sp_rpt_barang_jadi_accounting";					if($print == 1){			$this->rpc_service->setSP(array("sp"=> $sp,"mode"=> $print == 1 ? "2" : "1","debug"=>"1"));		} else {			$this->rpc_service->setSP($sp);		}				$this->rpc_service->addField('date_start',$date_start);		$this->rpc_service->addField('date_end',$date_end);		$this->rpc_service->addField('format',$format);		$this->rpc_service->addField('temp_folder',sys_get_temp_dir());		$this->rpc_service->addField('sort',$sort);		$this->rpc_service->addField('limit',$limit);		$this->rpc_service->addField('offset',$offset);						$this->rpc_service->setWhere($search,$filterRules,$field);				if($print == 1){						//$result = $this->rpc_service->resultPrint2();			//var_dump('coba');die();			$result = $this->rpc_service->resultPrint_laporan('','','','',$format,$date_start,$date_end);		    echo json_encode($result);		} else {			$this->authentication->plainlayout();									$result = $this->rpc_service->resultJSON_pop();				$data_result = json_decode($result['data'],true);			//var_dump($data_result);			if(isset($data_result['detail']['result_count'])){				$records = $data_result['detail']['result_count'];				$total = ceil($data_result['detail']['result_count'] / $limit);			} else {				$records = 0;				$total = 0;			}						$responce = new stdclass();			$responce->page = $page;			$responce->records = $records;			$responce->total = $total;			$i=0; 			if($data_result){				if(isset($data_result['xrow'])){					foreach($data_result['xrow'] as $key=>$value){						foreach ($value as $k => $v) {							//	if($k=='r5'){							//	 $v=$this->mainconfig->get_decimal_format($v,4,true);								//	}							//	if($k=='r7'){							//	 $v=$this->mainconfig->get_decimal_format($v,4,true);								//	}							//	if($k=='r8'){							//	 $v=$this->mainconfig->get_decimal_format($v,4,true);								//	}							//	if($k=='r9'){							//	 $v=$this->mainconfig->get_decimal_format($v,4,true);								//	}							$responce->rows[$i][$k] = $v;						} 						$i++;					}				}			}		 // var_dump($responce);			echo json_encode($responce);		}	}			function print_barang_jadi(){		$format = isset($_REQUEST['format']) ? $_REQUEST['format'] : false;		$date_start = isset($_REQUEST['date_start']) ? $_REQUEST['date_start'] : false;		$date_end = isset($_REQUEST['date_end']) ? $_REQUEST['date_end'] : false;		//var_dump($date_start ." dan ".$format);die();		  if ($format =='xlsx'){			$this->print_transfer_excel_new();  			//$this->print_transfer_excel();		  }else{			 // var_dump($grn_id);die();			  $this->print_transfer_pdf();		  }		 // die();		//   $return['status_code'] = $grn_id;		//   return $return;	}		function print_barang_jadi2(){		$format = isset($_REQUEST['format']) ? $_REQUEST['format'] : false;		$date_start = isset($_REQUEST['date_start']) ? $_REQUEST['date_start'] : false;		$date_end = isset($_REQUEST['date_end']) ? $_REQUEST['date_end'] : false;		//var_dump($date_start ." dan ".$format);die();		  if ($format =='xlsx'){			   var_dump("cccc");die();			$this->print_transfer_excel();		  }else{			 // var_dump($grn_id);die();			  $this->print_transfer_pdf();		  }	}		function print_report_accounting_excel_awal(){	   $this->load->model('main');	   $this->load->library('excel');	   	   $format = isset($_REQUEST['format']) ? $_REQUEST['format'] : false;	   $date_start = isset($_REQUEST['date_start']) ? $_REQUEST['date_start'] : false;	   $date_end = isset($_REQUEST['date_end']) ? $_REQUEST['date_end'] : false;	   	    	   	if(strlen(trim($date_start)) == 0 ){			$date_start = '1900-01-01';		}				if(strlen(trim($date_end)) == 0 ){			$date_end = '9999-12-31';		}			       $user_id = $this->session->userdata('user_id');	   	   $report_time=date('_Ymd_His'); 	   $excel = new PHPExcel();       // Settingan awal fil excel       $excel->getProperties()->setCreator('My Notes Code')                 ->setLastModifiedBy('My Notes Code')                 ->setTitle("Report Mutasi Barang Jadi")                 ->setSubject("Report Mutasi Barang Jadi")                 ->setDescription("Dokumen Mutasi Barang Jadi")                 ->setKeywords("Mutasi Barang Jadi");				 		   // Buat sebuah variabel untuk menampung pengaturan style dari header tabel		$style_col_header = array(		                   'font' => array('bold' => true), // Set font nya jadi bold                           'alignment' => array(                           'horizontal' => PHPExcel_Style_Alignment::HORIZONTAL_LEFT, // Set text jadi ditengah secara horizontal (center)                           'vertical' => PHPExcel_Style_Alignment::VERTICAL_CENTER // Set text jadi di tengah secara vertical (middle)                         )		           );				$style_row_header = array(		                   'alignment' => array(                           'horizontal' => PHPExcel_Style_Alignment::HORIZONTAL_LEFT, // Set text jadi ditengah secara horizontal (center)                           'vertical' => PHPExcel_Style_Alignment::VERTICAL_CENTER // Set text jadi di tengah secara vertical (middle)                         )		           );        $style_col = array(                        'font' => array('bold' => true), // Set font nya jadi bold                        'alignment' => array(                        'horizontal' => PHPExcel_Style_Alignment::HORIZONTAL_CENTER, // Set text jadi ditengah secara horizontal (center)                        'vertical' => PHPExcel_Style_Alignment::VERTICAL_CENTER // Set text jadi di tengah secara vertical (middle)                       ),                      'borders' => array(                      'top' => array('style'  => PHPExcel_Style_Border::BORDER_THIN), // Set border top dengan garis tipis                      'right' => array('style'  => PHPExcel_Style_Border::BORDER_THIN),  // Set border right dengan garis tipis                      'bottom' => array('style'  => PHPExcel_Style_Border::BORDER_THIN), // Set border bottom dengan garis tipis                      'left' => array('style'  => PHPExcel_Style_Border::BORDER_THIN) // Set border left dengan garis tipis                      )          );		           // Buat sebuah variabel untuk menampung pengaturan style dari isi tabel         $style_row = array(                        'alignment' => array(                        'vertical' => PHPExcel_Style_Alignment::VERTICAL_CENTER // Set text jadi di tengah secara vertical (middle)                        ),                        'borders' => array(                        'top' => array('style'  => PHPExcel_Style_Border::BORDER_THIN), // Set border top dengan garis tipis                        'right' => array('style'  => PHPExcel_Style_Border::BORDER_THIN),  // Set border right dengan garis tipis                        'bottom' => array('style'  => PHPExcel_Style_Border::BORDER_THIN), // Set border bottom dengan garis tipis                        'left' => array('style'  => PHPExcel_Style_Border::BORDER_THIN) // Set border left dengan garis tipis        ));			   $excel->setActiveSheetIndex(0)->setCellValue('A1', "REPORT MUTASI BARANG JADI"); // Set kolom A1 dengan tulisan "DATA SISWA"	   $excel->getActiveSheet()->mergeCells('A1:G1'); // Set Merge Cell pada kolom A1 sampai L1       $excel->getActiveSheet()->getStyle('A1')->getFont()->setBold(TRUE); // Set bold kolom A1       $excel->getActiveSheet()->getStyle('A1')->getFont()->setSize(12); // Set font size 15 untuk kolom A1       $excel->getActiveSheet()->getStyle('A1')->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_CENTER); // Set text center untuk kolom A1	   	   $excel->setActiveSheetIndex(0)->setCellValue('A2','PERIODE : '.$date_start.'  s/d  '.$date_end); // Set kolom A1 dengan tulisan "DATA SISWA"	   $excel->getActiveSheet()->mergeCells('A2:G2'); // Set Merge Cell pada kolom A1 sampai L1       $excel->getActiveSheet()->getStyle('A2')->getFont()->setBold(TRUE); // Set bold kolom A1       $excel->getActiveSheet()->getStyle('A2')->getFont()->setSize(12); // Set font size 15 untuk kolom A1       $excel->getActiveSheet()->getStyle('A2')->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_CENTER); // Set text center untuk kolom A1	   	   // -------- Header Table ------------	   $excel->setActiveSheetIndex(0)->setCellValue('A3', "NO"); // Set kolom A3 dengan tulisan "NO"	   $excel->getActiveSheet()->getStyle('A3')->applyFromArray($style_col);	   //  $excel->getActiveSheet()->getStyle('A4')->applyFromArray($style_col_header);	   $excel->getActiveSheet()->getStyle('A3')->getFont()->setSize(9); // Set font size 15 untuk kolom A1	   $excel->getActiveSheet()->getStyle('A3')->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_CENTER);	   	   $excel->setActiveSheetIndex(0)->setCellValue('B3', "KODE BARANG"); 	   $excel->getActiveSheet()->getColumnDimension('B')->setWidth(20);	   $excel->getActiveSheet()->getStyle('B3')->applyFromArray($style_col);	   $excel->getActiveSheet()->getStyle('B3')->getFont()->setSize(9); // Set font size 15 untuk kolom A1	   $excel->getActiveSheet()->getStyle('B3')->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_CENTER);	   	   $excel->setActiveSheetIndex(0)->setCellValue('C3', "NAMA BARANG"); 	   $excel->getActiveSheet()->getColumnDimension('C')->setWidth(40);	   $excel->getActiveSheet()->getStyle('C3')->applyFromArray($style_col);	   $excel->getActiveSheet()->getStyle('C3')->getFont()->setSize(9); // Set font size 15 untuk kolom A1	   $excel->getActiveSheet()->getStyle('C3')->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_CENTER);	   	   $excel->setActiveSheetIndex(0)->setCellValue('D3', "SATUAN"); 	   $excel->getActiveSheet()->getColumnDimension('D')->setWidth(15);	   $excel->getActiveSheet()->getStyle('D3')->applyFromArray($style_col);	   $excel->getActiveSheet()->getStyle('D3')->getFont()->setSize(9); // Set font size 15 untuk kolom A1	   $excel->getActiveSheet()->getStyle('D3')->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_CENTER);	   	   $excel->setActiveSheetIndex(0)->setCellValue('E3', "TOTAL QUANTITY"); 	   $excel->getActiveSheet()->getColumnDimension('E')->setWidth(25);	   $excel->getActiveSheet()->getStyle('E3')->applyFromArray($style_col);	   $excel->getActiveSheet()->getStyle('E3')->getFont()->setSize(9); // Set font size 15 untuk kolom A1	   $excel->getActiveSheet()->getStyle('E3')->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_CENTER);	   	   $excel->setActiveSheetIndex(0)->setCellValue('F3', "HARGA"); 	   $excel->getActiveSheet()->getColumnDimension('F')->setWidth(25);	   $excel->getActiveSheet()->getStyle('F3')->applyFromArray($style_col);	   $excel->getActiveSheet()->getStyle('F3')->getFont()->setSize(9); // Set font size 15 untuk kolom A1	   $excel->getActiveSheet()->getStyle('F3')->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_CENTER);	   	   $excel->setActiveSheetIndex(0)->setCellValue('G3', "TOTAL HARGA"); 	   $excel->getActiveSheet()->getColumnDimension('G')->setWidth(30);	   $excel->getActiveSheet()->getStyle('G3')->applyFromArray($style_col);	   $excel->getActiveSheet()->getStyle('G3')->getFont()->setSize(9); // Set font size 15 untuk kolom A1	   $excel->getActiveSheet()->getStyle('G3')->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_CENTER);	   	   $excel->getActiveSheet()->getRowDimension('3')->setRowHeight(20);	   	   $rpt_barang_jadi=$this->main->print_barang_jadi_report_accounting($date_start,$date_end);	   $i=1;		   $numrow = 4; // Set baris pertama untuk isi tabel adalah baris ke 4	  // var_dump( $rpt_barang_jadi);die();	   foreach($rpt_barang_jadi as $brg_jadi){		  $excel->setActiveSheetIndex(0)->setCellValue('A'.$numrow, $i);		  $excel->getActiveSheet()->getStyle('A'.$numrow)->applyFromArray($style_row);		  $excel->getActiveSheet()->getStyle('A'.$numrow)->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_CENTER);		  $excel->getActiveSheet()->getStyle('A'.$numrow)->getFont()->setSize(9); // Set font size 15 untuk kolom A1		  		  $excel->setActiveSheetIndex(0)->setCellValue('B'.$numrow, $brg_jadi['r1']);		  $excel->getActiveSheet()->getStyle('B'.$numrow)->applyFromArray($style_row);		  $excel->getActiveSheet()->getStyle('B'.$numrow)->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_LEFT);		  $excel->getActiveSheet()->getStyle('B'.$numrow)->getFont()->setSize(9);		   		  $excel->setActiveSheetIndex(0)->setCellValue('C'.$numrow, $brg_jadi['r2']);		  $excel->getActiveSheet()->getStyle('C'.$numrow)->applyFromArray($style_row);		  $excel->getActiveSheet()->getStyle('C'.$numrow)->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_LEFT);		  $excel->getActiveSheet()->getStyle('C'.$numrow)->getFont()->setSize(9);		  		  $excel->setActiveSheetIndex(0)->setCellValue('D'.$numrow, $brg_jadi['r3']);		  $excel->getActiveSheet()->getStyle('D'.$numrow)->applyFromArray($style_row);		  $excel->getActiveSheet()->getStyle('D'.$numrow)->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_CENTER);		  $excel->getActiveSheet()->getStyle('D'.$numrow)->getFont()->setSize(9);		  		  $excel->setActiveSheetIndex(0)->setCellValue('E'.$numrow, $brg_jadi['r4']);		  $excel->getActiveSheet()->getStyle('E'.$numrow)->applyFromArray($style_row);		  $excel->getActiveSheet()->getStyle('E'.$numrow)->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_CENTER);		  $excel->getActiveSheet()->getStyle('E'.$numrow)->getFont()->setSize(9);		  		  $excel->setActiveSheetIndex(0)->setCellValue('F'.$numrow, $brg_jadi['r5']);		  $excel->getActiveSheet()->getStyle('F'.$numrow)->applyFromArray($style_row);		  $excel->getActiveSheet()->getStyle('F'.$numrow)->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_RIGHT);		  $excel->getActiveSheet()->getStyle('F'.$numrow)->getFont()->setSize(9);		  		  $excel->setActiveSheetIndex(0)->setCellValue('G'.$numrow, $brg_jadi['r6']);		  $excel->getActiveSheet()->getStyle('G'.$numrow)->applyFromArray($style_row);		  $excel->getActiveSheet()->getStyle('G'.$numrow)->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_RIGHT);		  $excel->getActiveSheet()->getStyle('G'.$numrow)->getFont()->setSize(9);		 		 $i++;		 $numrow++;  	   }	   	     $excel->getActiveSheet()->getDefaultRowDimension()->setRowHeight(-1);         // Set orientasi kertas jadi LANDSCAPE         $excel->getActiveSheet()->getPageSetup()->setOrientation(PHPExcel_Worksheet_PageSetup::ORIENTATION_PORTRAIT);         // Set judul file excel nya         $excel->getActiveSheet(0)->setTitle("Report_Mutasi_Barang_Jadi");         $excel->setActiveSheetIndex(0);		 //$nama_file='Bukti_barang_Transfer'.$report_time.'.xlsx';		   // Proses file excel         header('Content-Type: application/vnd.openxmlformats-officedocument.spreadsheetml.sheet');         header('Content-Disposition: attachment; filename="Report_Mutasi_Barang_Jadi'.$report_time.'.xlsx"'); // Set nama file excel nya		 header('Cache-Control: max-age=0');		 		 header("Content-Type: application/force-download");		 header("Content-Type: application/download");				          $write = PHPExcel_IOFactory::createWriter($excel, 'Excel2007');		 $write->save('php://output');	}	   function print_report_accounting_excel(){	   	    $this->db_pop = $this->load->database('pop', TRUE);		$this->load->model('main');			//$this->load->library('excel');		$format = isset($_REQUEST['format']) ? $_REQUEST['format'] : false;		$date_start = isset($_REQUEST['date_start']) ? $_REQUEST['date_start'] : false;		$date_end = isset($_REQUEST['date_end']) ? $_REQUEST['date_end'] : false;			    // $date_start = isset($_REQUEST['date_start']) ?  $_REQUEST['date_start'] : '';		//$date_end = isset($_REQUEST['date_end']) ? $_REQUEST['date_end'] : '';		//$item_id = isset($_REQUEST['item_id']) ? $_REQUEST['item_id'] : '';			require_once APPPATH."/third_party/PHPExcel.php"; 		require_once APPPATH."/third_party/PHPExcel/IOFactory.php"; 				$phpExcel = PHPExcel_IOFactory::load(FCPATH."/assets/template/Report_accounting_barang_jadi.xlsx");			$phpExcel->setActiveSheetIndex(0);  //set first sheet as active				// ,COALESCE(c.quantity,0) + COALESCE(d.quantity,0) + COALESCE(e.quantity,0) + COALESCE(f.quantity,0) as r4		$q_old = $this->db->query("select 		 a.item_base_code as r1		 ,COALESCE(a.item_base_name,'') as r2		 ,b.uom_code as r3		 ,COALESCE(c.quantity,0) + COALESCE(d.quantity,0) + COALESCE(e.quantity,0) + COALESCE(f.quantity,0) as r4		 ,COALESCE(j.price,0) as r5		 ,(COALESCE(c.quantity,0) + COALESCE(d.quantity,0) + COALESCE(e.quantity,0) + COALESCE(f.quantity,0)) * COALESCE(j.price,0) as r6		from dbo.dt_mst_item_base a		Left Join dbo.ref_uom b ON a.uom_id = b.uom_id		Left Join dbo.sp_mutasi_saldo_awal('$date_start') c ON a.item_base_id = c.item_base_id		Left Join dbo.sp_mutasi_pemasukan('$date_start','$date_end' ) d ON a.item_base_id = d.item_base_id	  Left Join dbo.sp_mutasi_pengeluaran('$date_start','$date_end' ) e ON a.item_base_id = e.item_base_id		Left Join dbo.sp_mutasi_penyesuaian('$date_start','$date_end' ) f ON a.item_base_id = f.item_base_id  	Left Join dbo.sp_mutasi_stock_opname('$date_start','$date_end' ) g ON a.item_base_id = g.item_base_id		LEFT JOIN dbo.dt_mst_item_category h ON a.item_category_id = h.item_category_id	  Left Join dbo.prm_custom_item_type i ON h.custom_item_type_id = i.custom_item_type_id		LEFT JOIN (SELECT             b.item_base_id,             a.price,            a.stock_move_date,             ROW_NUMBER() OVER(PARTITION BY b.item_base_id ORDER BY a.stock_move_date DESC) as rn         from dbo.dt_stock_move a		     Left Join dbo.dt_mst_item b ON a.item_id = b.item_id          WHERE (		     	(a.app_trans_id IN (22) AND a.quantity < 0) 			      OR (a.app_trans_id IN (39) AND a.delivery_detail_id is null)			      OR (a.app_trans_id IN (50) AND a.consumable_detail_id is null)	      	)  AND a.price is not NULL     ) j ON a.item_base_id = j.item_base_id AND rn = 1		where i.custom_item_type_id = 2 AND (COALESCE(c.quantity,0) + COALESCE(d.quantity,0) + COALESCE(e.quantity,0) + COALESCE(f.quantity,0)) !=0 ");				$bagus= $this->db->query("select 		 a.item_base_code as r1		 ,COALESCE(a.item_base_name,'') as r2		 ,b.uom_code as r3		 ,case when c.quantity is null then 0 ::numeric else c.quantity end as r4		 ,case when d.quantity is null then 0 ::numeric else d.quantity end as r5		 ,case when e.quantity is null then 0 ::numeric else e.quantity end as r6 		 ,case when f.quantity is null then 0 ::numeric else f.quantity end as r7		 ,CASE		  WHEN COALESCE(j.price,0) = 0 then COALESCE(k.price,0)		  else COALESCE(j.price,0) 			END as r8		from dbo.dt_mst_item_base a		Left Join dbo.ref_uom b ON a.uom_id = b.uom_id		Left Join dbo.sp_mutasi_saldo_awal('$date_start') c ON a.item_base_id = c.item_base_id		Left Join dbo.sp_mutasi_pemasukan('$date_start','$date_end' ) d ON a.item_base_id = d.item_base_id	  Left Join dbo.sp_mutasi_pengeluaran('$date_start','$date_end' ) e ON a.item_base_id = e.item_base_id		Left Join dbo.sp_mutasi_penyesuaian('$date_start','$date_end' ) f ON a.item_base_id = f.item_base_id  	Left Join dbo.sp_mutasi_stock_opname('$date_start','$date_end' ) g ON a.item_base_id = g.item_base_id		LEFT JOIN dbo.dt_mst_item_category h ON a.item_category_id = h.item_category_id	  Left Join dbo.prm_custom_item_type i ON h.custom_item_type_id = i.custom_item_type_id		LEFT JOIN (SELECT             b.item_base_id,             a.price,            a.stock_move_date,             ROW_NUMBER() OVER(PARTITION BY b.item_base_id ORDER BY a.stock_move_date DESC) as rn         from dbo.dt_stock_move a		     Left Join dbo.dt_mst_item b ON a.item_id = b.item_id          WHERE (		     	(a.app_trans_id IN (22) AND a.quantity < 0) 			      OR (a.app_trans_id IN (39) AND a.delivery_detail_id is null)			      OR (a.app_trans_id IN (50) AND a.consumable_detail_id is null)	      	)  AND a.price is not NULL     ) j ON a.item_base_id = j.item_base_id AND rn = 1 LEFT JOIN dbo.view_harga_masuk k ON a.item_base_id = k.item_base_id 	 where i.custom_item_type_id = 2 AND k.rn = 1 AND (COALESCE(c.quantity,0) + COALESCE(d.quantity,0) + COALESCE(e.quantity,0) + COALESCE(f.quantity,0)) !=0 ");						 $q = $this->db_pop->query("select 		 a.item_base_code as r1		 ,COALESCE(a.item_base_name,'') as r2		 ,b.uom_code as r3		 ,case when c.quantity is null then 0 ::numeric else c.quantity end as r4		 ,case when d.quantity is null then 0 ::numeric else d.quantity end as r5		 ,case when e.quantity is null then 0 ::numeric else e.quantity end as r6 		 ,case when f.quantity is null then 0 ::numeric else f.quantity end as r7		 ,CASE		  WHEN COALESCE(j.price,0) = 0 then COALESCE(k.price,0)		  else COALESCE(j.price,0) 			END as r8		from dbo.view_mst_item_base_ecc a		Left Join dbo.ref_uom b ON a.uom_id = b.uom_id		Left Join dbo.sp_mutasi_saldo_awal_new('$date_start') c ON a.item_base_id = c.item_base_id		Left Join dbo.sp_mutasi_pemasukan_new('$date_start','$date_end') d ON a.item_base_id = d.item_base_id	  Left Join dbo.sp_mutasi_pengeluaran_new('$date_start','$date_end') e ON a.item_base_id = e.item_base_id		Left Join dbo.sp_mutasi_penyesuaian('$date_start','$date_end') f ON a.item_base_id = f.item_base_id  	Left Join dbo.sp_mutasi_stock_opname('$date_start','$date_end') g ON a.item_base_id = g.item_base_id		LEFT JOIN dbo.dt_mst_item_category h ON a.item_category_id = h.item_category_id	  Left Join dbo.prm_custom_item_type i ON h.custom_item_type_id = i.custom_item_type_id		LEFT JOIN dbo.view_harga_keluar j ON a.item_base_id = j.item_base_id		LEFT JOIN dbo.view_harga_masuk k ON a.item_base_id = k.item_base_id 		where i.custom_item_type_id = 2 and k.rn = 1 AND (COALESCE(c.quantity,0) + COALESCE(d.quantity,0) + COALESCE(e.quantity,0) + COALESCE(f.quantity,0)) !=0 ");				$phpExcel->getActiveSheet()->setCellValueExplicit("A2","PERIODE : ".$date_start . " s/d " . $date_end, PHPExcel_Cell_DataType::TYPE_STRING);					$styleArray = array(			'font'  => array(				//'bold'  => true,				//'color' => array('rgb' => '249007'),				//'size'  => 15,				//'name'  => 'Verdana'			),			'borders' => array(				'allborders' => array(				  'style' => PHPExcel_Style_Border::BORDER_THIN				)			  )		);		$styleArray1 = array(		'font'  => array(			//'bold'  => true,			//'color' => array('rgb' => '1a57e3'),			//'size'  => 15,			//'name'  => 'Verdana'		),		'borders' => array(				'allborders' => array(				  'style' => PHPExcel_Style_Border::BORDER_THIN				)			  )				);				$i = 3;		$j = '';		$k = 1;		$l=1;		$jml = 0;		//$rpt_barang_jadi=$this->main->print_barang_jadi_report_accounting($date_start,$date_end);		// foreach($rpt_barang_jadi as $brg_jadi){		foreach ($q->result() as $r){			$k = 1 + $i;			$j = "$k";						//$phpExcel->getActiveSheet()->getStyle('G'.$j)->getNumberFormat()->setFormatCode('#,##0');						//$r4=$this->mainconfig->get_decimal_format( $r->r4,2,true);			//$r5=$this->mainconfig->get_decimal_format( $r->r5,2,true);			$jumlah= $r->r4 + $r->r5 + $r->r6 + $r->r7 ;  			$harga = $r->r8 ;			$total = $jumlah * $harga ;			//$r6=$r4 * $r5 ;			//$r6=$this->mainconfig->get_decimal_format( $r->r6,2,true);						$phpExcel->getActiveSheet()->setCellValue("A".$j, $l);			$phpExcel->getActiveSheet()->setCellValueExplicit("B".$j, $r->r1, PHPExcel_Cell_DataType::TYPE_STRING);			$phpExcel->getActiveSheet()->setCellValueExplicit("C".$j, $r->r2, PHPExcel_Cell_DataType::TYPE_STRING);			$phpExcel->getActiveSheet()->setCellValueExplicit("D".$j, $r->r3, PHPExcel_Cell_DataType::TYPE_STRING);			$phpExcel->getActiveSheet()->setCellValue("E".$j, $jumlah);			$phpExcel->getActiveSheet()->setCellValue("F".$j, $harga);			$phpExcel->getActiveSheet()->setCellValue("G".$j, $total);						//$phpExcel->getActiveSheet()->setCellValueExplicit("B".$j, $brg_jadi['r1'], PHPExcel_Cell_DataType::TYPE_STRING);			//$phpExcel->getActiveSheet()->setCellValueExplicit("C".$j, $brg_jadi['r2'], PHPExcel_Cell_DataType::TYPE_STRING);			//$phpExcel->getActiveSheet()->setCellValueExplicit("D".$j, $brg_jadi['r3'], PHPExcel_Cell_DataType::TYPE_STRING);			//$phpExcel->getActiveSheet()->setCellValueExplicit("E".$j, $brg_jadi['r4']);			//$phpExcel->getActiveSheet()->setCellValueExplicit("F".$j, $brg_jadi['r5']);			//$phpExcel->getActiveSheet()->setCellValueExplicit("G".$j, $brg_jadi['r6']);		    $phpExcel->getActiveSheet()->getStyle('E'.$j)->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_RIGHT);			$phpExcel->getActiveSheet()->getStyle('F'.$j)->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_RIGHT);			$phpExcel->getActiveSheet()->getStyle('G'.$j)->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_RIGHT);			//$phpExcel->getActiveSheet()->getStyle('G'.$j)->getNumberFormat()->setFormatCode(PHPExcel_Style_NumberFormat::FORMAT_NUMBER_COMMA_SEP);			//$phpExcel->getActiveSheet()->getStyle('G'.$j)->getNumberFormat()->setFormatCode('#,##0');			            //$phpExcel->getActiveSheet()->getStyle('G'.$j)->getNumberFormat()->setFormatCode('#,##0.00');			//$worksheet->getStyle('A1')->getNumberFormat()->setFormatCode(PHPExcel_Style_NumberFormat::FORMAT_NUMBER_COMMA_SEP);            // Atau menggunakan kode kustom: $worksheet->getStyle('A1')->getNumberFormat()->setFormatCode('#,##0');			$phpExcel->getActiveSheet()->getStyle("E".$j)->getNumberFormat()->setFormatCode('#,##0.0000');			$phpExcel->getActiveSheet()->getStyle("F".$j)->getNumberFormat()->setFormatCode('#,##0.0000');			$phpExcel->getActiveSheet()->getStyle("G$j")->getNumberFormat()->setFormatCode('#,##0.0000');							$phpExcel->getActiveSheet()->getStyle("A$j")->applyFromArray($styleArray);				$phpExcel->getActiveSheet()->getStyle("B$j")->applyFromArray($styleArray);				$phpExcel->getActiveSheet()->getStyle("C$j")->applyFromArray($styleArray);				$phpExcel->getActiveSheet()->getStyle("D$j")->applyFromArray($styleArray);				$phpExcel->getActiveSheet()->getStyle("E$j")->applyFromArray($styleArray);				$phpExcel->getActiveSheet()->getStyle("F$j")->applyFromArray($styleArray);				$phpExcel->getActiveSheet()->getStyle("G$j")->applyFromArray($styleArray);											//$jml = $jml + $r->qty;			//echo $jml . '<br />';			//$phpExcel->getActiveSheet()->getStyle("A10:"."A".$j)->getBorders()->getLeft()->setBorderStyle(PHPExcel_Style_Border::BORDER_THIN);			$l++;			$i++;		} 		$report_time=date('_Ymd_His'); 		//$x = $k+1;		//$phpExcel->getActiveSheet()->setCellValue("G".$x, $jml);						//$filename =  "Report_Mutasi_Barang_Jadi"  . $date_start . '_' . $date_end;		$filename =  "Report_Mutasi_Barang_Jadi " . $report_time;		header('Content-Type: application/vnd.openxmlformats-officedocument.spreadsheetml.sheet');		header('Content-Disposition: attachment;filename="'.$filename.'.xlsx"');				header("Pragma:no-cache");		header("Cache-Control:must-revalidate, post-check=0, pre-check=0");				header('Cache-Control: max-age=0');		header("Content-Type: application/force-download");	    header("Content-Type: application/download");				header("Expires:0");		$objWriter = PHPExcel_IOFactory::createWriter($phpExcel, 'Excel2007');  //downloadable file is in Excel 2003 format (.xls)		$objWriter->save('php://output');  //send it to user, of course you can save it to disk also!		 		exit; //done.. exiting!		       					}		function print_transfer_excel_old_2(){	   $this->load->library('excel');	   	   $format = isset($_REQUEST['format']) ? $_REQUEST['format'] : false;	   $date_start = isset($_REQUEST['date_start']) ? $_REQUEST['date_start'] : false;	   $date_end = isset($_REQUEST['date_end']) ? $_REQUEST['date_end'] : false;	   	    $page = isset($_POST['page'])?$_POST['page']:1; // get the requested page         $rows = isset($_POST['rows'])?$_POST['rows']:10; // get how many rows we want to have into the grid         $sidx = isset($_POST['sidx'])?$_POST['sidx']:'r1'; // get index row - i.e. user click to sort         $sord = isset($_POST['sord'])?$_POST['sord']:'0'; // get the direction 		$search = isset($_REQUEST['_search'])?$_REQUEST['_search']:false; 		$filterRules =  isset($_POST['filters'])?$_POST['filters']:false;		//var_dump($date_end);die();				$limit =  $rows;		$offset =  $rows * ($page - 1);						$order = isset($_REQUEST['order']) ? $_REQUEST['order'] : array();				if($sord == 'asc'){			$sord = 1;		} else {			$sord = 2;		}				$sort =	$sidx. '='.$sord;							if(strlen(trim($date_start)) == 0 ){			$date_start = '1900-01-01';		}				if(strlen(trim($date_end)) == 0 ){			$date_end = '9999-12-31';		}			       $user_id = $this->session->userdata('user_id');	   	   $report_time=date('_Ymd_His'); 	   $excel = new PHPExcel();       // Settingan awal fil excel       $excel->getProperties()->setCreator('My Notes Code')                 ->setLastModifiedBy('My Notes Code')                 ->setTitle("Report Barang Jadi")                 ->setSubject("Report Barang Jadi")                 ->setDescription("Surat Report Barang Jadi")                 ->setKeywords("Report Barang Jadi");				 		   // Buat sebuah variabel untuk menampung pengaturan style dari header tabel		$style_col_header = array(		                   'font' => array('bold' => true), // Set font nya jadi bold                           'alignment' => array(                           'horizontal' => PHPExcel_Style_Alignment::HORIZONTAL_LEFT, // Set text jadi ditengah secara horizontal (center)                           'vertical' => PHPExcel_Style_Alignment::VERTICAL_CENTER // Set text jadi di tengah secara vertical (middle)                         )		           );				$style_row_header = array(		                   'alignment' => array(                           'horizontal' => PHPExcel_Style_Alignment::HORIZONTAL_LEFT, // Set text jadi ditengah secara horizontal (center)                           'vertical' => PHPExcel_Style_Alignment::VERTICAL_CENTER // Set text jadi di tengah secara vertical (middle)                         )		           );        $style_col = array(                        'font' => array('bold' => true), // Set font nya jadi bold                        'alignment' => array(                        'horizontal' => PHPExcel_Style_Alignment::HORIZONTAL_CENTER, // Set text jadi ditengah secara horizontal (center)                        'vertical' => PHPExcel_Style_Alignment::VERTICAL_CENTER // Set text jadi di tengah secara vertical (middle)                       ),                      'borders' => array(                      'top' => array('style'  => PHPExcel_Style_Border::BORDER_THIN), // Set border top dengan garis tipis                      'right' => array('style'  => PHPExcel_Style_Border::BORDER_THIN),  // Set border right dengan garis tipis                      'bottom' => array('style'  => PHPExcel_Style_Border::BORDER_THIN), // Set border bottom dengan garis tipis                      'left' => array('style'  => PHPExcel_Style_Border::BORDER_THIN) // Set border left dengan garis tipis                      )          );		           // Buat sebuah variabel untuk menampung pengaturan style dari isi tabel         $style_row = array(                        'alignment' => array(                        'vertical' => PHPExcel_Style_Alignment::VERTICAL_CENTER // Set text jadi di tengah secara vertical (middle)                        ),                        'borders' => array(                        'top' => array('style'  => PHPExcel_Style_Border::BORDER_THIN), // Set border top dengan garis tipis                        'right' => array('style'  => PHPExcel_Style_Border::BORDER_THIN),  // Set border right dengan garis tipis                        'bottom' => array('style'  => PHPExcel_Style_Border::BORDER_THIN), // Set border bottom dengan garis tipis                        'left' => array('style'  => PHPExcel_Style_Border::BORDER_THIN) // Set border left dengan garis tipis        ));	  	   $excel->setActiveSheetIndex(0)->setCellValue('A1', "REPORT BARANG JADI"); // Set kolom A1 dengan tulisan "DATA SISWA"	   $excel->getActiveSheet()->mergeCells('A1:G1'); // Set Merge Cell pada kolom A1 sampai L1       $excel->getActiveSheet()->getStyle('A1')->getFont()->setBold(TRUE); // Set bold kolom A1       $excel->getActiveSheet()->getStyle('A1')->getFont()->setSize(14); // Set font size 15 untuk kolom A1       $excel->getActiveSheet()->getStyle('A1')->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_CENTER); // Set text center untuk kolom A1	   	   $excel->setActiveSheetIndex(0)->setCellValue('A2', $date_start." s/d ".$date_end); // Set kolom A1 dengan tulisan "DATA SISWA"	   $excel->getActiveSheet()->mergeCells('A2:G2'); // Set Merge Cell pada kolom A1 sampai L1       $excel->getActiveSheet()->getStyle('A2')->getFont()->setBold(TRUE); // Set bold kolom A1       $excel-