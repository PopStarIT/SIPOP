m['where']['0']['data'] = $supp_trans_detail_id;		} else {			$view = 'view_supp_trans_invoice_item';			$extra_param['where']['0']['field'] = 'r18';			$extra_param['where']['0']['data'] = $partner_id;			$extra_param['where']['1']['field'] = 'r19';			$extra_param['where']['1']['data'] = $currencies_id;		}				$extra_param['field']['rh_id'] = $supp_trans_detail_id;						$extra_param['methodid'] = $methodid;				$loaddata = $this->ecc_library->get_field_data($view,$field,$extra_param);					echo $loaddata;	}		function loaddata_tax(){				$component['loadlayout'] = true;		$component['view_load'] = 'transaction/supplier_invoice/tax_form';				$supp_trans_detail_id = isset($_REQUEST['supp_trans_detail_id']) ?  $_REQUEST['supp_trans_detail_id'] : '';		$methodid = isset($_REQUEST['methodid']) ?  $_REQUEST['methodid'] : '';				$this->rpc_service->setSP("dbo.sp_supp_trans_tax_load");		$this->rpc_service->addField('supp_trans_detail_id',$supp_trans_detail_id);				$result = $this->rpc_service->resultJSON();					$data_result = json_decode($result['data'],true);				if($data_result){			$supp_trans_detail_id = $data_result['detail']['supp_trans_detail_id'];			$component['supp_trans_detail_id'] = $supp_trans_detail_id;			$component['parent_methodid'] = $methodid;			$component['xrow'] = $data_result['xrow'];		}				$this->authentication->ajaxlayout($component);	}}?>