d']) ? $_REQUEST['supp_trans_id']  : -1 : -1;		$methodid = isset($_REQUEST['methodid']) ? is_numeric($_REQUEST['methodid']) ? $_REQUEST['methodid']  : -1 : -1;				$view = 'view_supp_trans_invoice_detail_gl';		$field = $this->supp_trans_invoice_detail_gl_table();				$return = array();		$return['valid'] = false;		$return['message'] = "Internal Server Error";				$extra_param = array();		$extra_param['where']['0']['field'] = 'r2';		$extra_param['where']['0']['data'] = $supp_trans_id;		$extra_param['methodid'] = $methodid;				$loaddata = $this->ecc_library->get_field_data($view,$field,$extra_param);					echo $loaddata;	}		function loaddata_detail(){		$this->authentication->plainlayout();				$supp_trans_id = isset($_REQUEST['supp_trans_id']) ? is_numeric($_REQUEST['supp_trans_id']) ? $_REQUEST['supp_trans_id']  : -1 : -1;		$methodid = isset($_REQUEST['methodid']) ? is_numeric($_REQUEST['methodid']) ? $_REQUEST['methodid']  : -1 : -1;				$view = 'view_supp_trans_invoice_detail';		$field = $this->supp_trans_invoice_detail_table();				$return = array();		$return['valid'] = false;		$return['message'] = "Internal Server Error";				$extra_param = array();		$extra_param['where']['0']['field'] = 'r2';		$extra_param['where']['0']['data'] = $supp_trans_id;		$extra_param['methodid'] = $methodid;				$loaddata = $this->ecc_library->get_field_data($view,$field,$extra_param);					echo $loaddata;	}		function post_add_edit_detail(){		$this->authentication->plainlayout();		$parameter = array();		$return = array();			$supp_trans_id = isset($_POST['supp_trans_id']) ? $_POST['supp_trans_id'] : 0;		$supp_trans_detail_id = isset($_POST['supp_trans_detail_id']) ? $_POST['supp_trans_detail_id'] : '';		$parent_id = isset($_POST['parent_id']) ? $_POST['parent_id'] : '';		$quantity_invoiced = isset($_POST['quantity_invoiced']) ? $_POST['quantity_invoiced'] : 0;		$unit_price = isset($_POST['unit_price']) ? $_POST['unit_price'] : '';				$user_id = 