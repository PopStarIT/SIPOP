?><?php if ( ! defined('BASEPATH')) exit('No direct script access allowed');Class Supplier_invoice extends CI_Controller { 	function __construct(){ 		parent::__construct(); 				$this->data_request = $_REQUEST;				$module = $this->router->module;		$directory = $this->router->directory;		$class = $this->router->class;		$method = $this->router->method;		$directory = trim(str_replace('../modules/'.$module ,'',str_replace('/controllers/','',$directory)),'/');				$this->module = $module;		if(trim($directory) != ''){			$this->directory = $directory;		} else {			$this->directory = '0';			$this->directory2 = '';		}		$this->class = $class;		$this->method = $method;	}		function supp_trans_invoice_table(){		$view = 'view_supp_trans_invoice';		$get_field = $this->ecc_library->get_field($view);				$get_field['r1']['hidden'] = true;				$get_field['r2']['title'] = "Invoice No";		$get_field['r3']['title'] = "Invoice Date";		$get_field['r4']['title'] = "Invoice Due Date";		$get_field['r6']['title'] = "Supplier Code";		$get_field['r7']['title'] = "Supplier Name";		$get_field['r8']['title'] = "Currencies";		$get_field['r14']['title'] = "Status";				$get_field['r19']['hidden'] = true;		$get_field['r20']['hidden'] = true;		$get_field['r21']['hidden'] = true;		$get_field['r22']['hidden'] = true;		$get_field['r23']['hidden'] = true;		$get_field['r24']['hidden'] = true;		$get_field['r25']['hidden'] = true;		$get_field['r26']['hidden'] = true;				return $get_field;	}		function supp_trans_invoice_detail_table() {		$view = 'view_supp_trans_invoice_detail';		$get_field = $this->ecc_library->get_field($view);				$get_field['r1']['hidden'] = true;		$get_field['r2']['hidden'] = true;				$get_field['r18']['hidden'] = true;				$get_field['act']['sc'] = 'act';		$get_field['act']['title'] = '#';		$get_field['act']['bypassvalue'] = '';		$get_field['act']['ctype'] = 'text';		$get_field['act']['align'] = 'center';		$get_field['act']['searc