			    try {
                       $object = PHPExcel_IOFactory::load($file_temp);
                    } catch(Exception $e) {
					   $return['valid'] = false;
	                   $return['message'] =  "Gagal membaca file: " . $e->getMessage();
                    // return "Gagal membaca file: " . $e->getMessage();
                   }
