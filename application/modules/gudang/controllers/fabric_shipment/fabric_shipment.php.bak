	,b.purchase_order_no,b.item_code,b.fabric_shipment_detail_invoice_number,b.quantity,d.item_base_code,b.weight,d.item_base_name,aa.colour,aa.jml_roll FROM dbo.dt_fabric_shipment a left join dbo.view_fabric_shipment_detail b ON a.fabric_shipment_id = b.fabric_shipment_id left join public.dt_mst_item c ON b.item_id = c.item_id left join public.dt_mst_item_base d ON c.item_base_id = d.item_base_id 	left JOIN ( select fabric_shipment_detail_id,fabric_shipment_list_colour as colour,count(fabric_shipment_list_roll) as jml_roll from dbo.dt_fabric_shipment_list 
  group by fabric_shipment_detail_id,fabric_shipment_list_colour ) aa ON b.fabric_shipment_detail_id = aa.fabric_shipment_detail_id WHERE a.fabric_shipment_id='. $fabric_shipment_id .'order by b.fabric_shipment_detail_id ASC ');
