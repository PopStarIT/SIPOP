<?php if ( ! defined('BASEPATH')) exit('No direct script access allowed');
Class Warehouse extends CI_Controller { 
	function __construct(){ 
		parent::__construct(); 
	} 		function index(){		$component['loadlayout'] = true;		$component['view_load'] = 'warehouse';				$dashboard_tab = array();				$tab_purchase = array('alias' => 'warehous', 'title' => 'warehouse', 'icon' => 'fa fa-building');		$tab_purchase_invoice = array('alias' => 'purchase_invoice', 'title' => 'Proforma Invoice', 'icon' => 'fa fa-shopping-basket');				$tab_purchase_content = array();		$tab_purchase_content[] = array('method_id' => 781113, 'menu_name' => 'Purchase Order Warehouse', 'menu_icon' => 'fa fa-shopping-basket');		$tab_purchase_content[] = array('method_id' => 781124, 'menu_name' => 'Shipment', 'menu_icon' => 'fa fa-truck');		$tab_purchase_content[] = array('method_id' => 781145, 'menu_name' => 'Item Receive', 'menu_icon' => 'fa fa-sign-in');		$tab_purchase_content[] = array('method_id' => 781168, 'menu_name' => 'Good Receive Warehouse2', 'menu_icon' => 'fa fa-university');		//$tab_purchase_content[] = array('method_id' => 918, 'menu_name' => 'Monitoring PO', 'menu_icon' => 'fa fa-cog');		$tab_purchase['content'] = $tab_purchase_content;				//$tab_purchase_invoice_content = array();		//$tab_purchase_invoice_content[] = array('method_id' => 160, 'menu_name' => 'Proforma Invoice', 'menu_icon' => 'fa fa-external-link');		//$tab_purchase_invoice['content'] = $tab_purchase_invoice_content;				$dashboard_tab[] = $tab_purchase;		//$dashboard_tab[] = $tab_purchase_invoice;						$component['dashboard_tab'] = $dashboard_tab;						$this->authentication->ajaxlayout($component);	}
}