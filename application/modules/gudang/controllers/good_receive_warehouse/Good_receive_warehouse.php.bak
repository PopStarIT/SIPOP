   function print_grn_excel(){
	   $this->load->library('excel');
	 // var_dump("masuk".$_REQUEST['grn_id']);die();
	  $grn_id = isset($_REQUEST['grn_id']) ? $_REQUEST['grn_id'] : false;
      $format = isset($_REQUEST['format']) ? $_REQUEST['format'] : 'xlsx';
	  
