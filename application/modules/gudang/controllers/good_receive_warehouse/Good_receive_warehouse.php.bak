			$this->rpc_service->addField('grn_date',$grn_date);
			$this->rpc_service->addField('warehouse_id',$warehouse_id);
			$this->rpc_service->addField('grn_type_id',$grn_type_id);
			$this->rpc_service->addField('partner_id',$partner_id);
			$this->rpc_service->addField('bc_in_header_id',$bc_in_header_id);
			$this->rpc_service->addField('purchase_order_id',$purchase_order_id);
			$this->rpc_service->addField('no_surat_jalan',$no_surat_jalan);
			$this->rpc_service->addField('tgl_surat_jalan',$tgl_surat_jalan);
		
            $result = $this->rpc_service->resultJSON();		
			
        //   $result = array('valid'=>true,'no'=>'0000','des'=>'', 'sts'=>json_encode(array('valid'=>true,'no'=>'0000','des'=>'')),'data'=>array('grn_no'=>'GRN-2025/08/12-0001','grn_type_id'=>4,
		//	'grn_id'=>'28065','partner_id'=>480));			
