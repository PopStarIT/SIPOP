	function loaddata() {
		$this->authentication->plainlayout();
		
		$view = 'view_grn';
		$field = $this->good_receive_table();
		
		$return = array();
		$return['valid'] = false;
		$return['message'] = "Internal Server Error";
 
		$loaddata = $this->ecc_library->get_field_data($view,$field);
			
		echo $loaddata;
	}
	
	function approve(){
		$this->authentication->plainlayout();
		$parameter = array();
		$return = array();
				
		$grn_id = isset($_POST['grn_id']) ? $_POST['grn_id'] : false;
		
		$user_id = $this->session->userdata('user_id');
		
		$result2 = array();
		$result = array();
		$return['valid'] = false;
		$return['status_code'] = 501;
		$return['message'] = "Internal Server Error lagi";
		
		if(count($_POST) > 0){
	        if($grn_id){
		      $this->rpc_service->setSP("dbo.sp_grn_approve");
			   $this->rpc_service->addField('grn_id',$grn_id);
			}
					
			$result = $this->rpc_service->resultJSON();
			
		//$result['valid']=true;
		//$result['data']=true;
		//$result['no']='00';
			
			$data = array();
			if(isset($result)){
				if(isset($result['valid'])){
					if($result['valid']){
						if(isset($result['data'])){
							//var_dump($grn_id);die();
							if($grn_id){
			                    $this->rpc_service->setSP("dbo.sp_grn_warehouse_approve");
			                    $this->rpc_service->addField('grn_id_sipop',$grn_id);
			                 }
							 
							$result2 = $this->rpc_service->resultJSON_pop();
							//var_dump($result2);die();
							if(isset($result2)){
							   if(isset($result2['valid'])){
					             if($result2['valid']){
						           if(isset($result2['data'])){
									  $return['valid'] = $result['valid'];
							          $return['status_code'] = $result['no'];
							          $return['message'] = $result['des'];
								   }
								 }else{
									 $return['valid'] = $result2['valid'];
									 $return['status_code'] =$result2['no'];
					         	     $return['message'] = $result2['des'];
								 }
							   }else{
								   $return['status_code'] = $result2['no'];
						           $return['message'] = $result2['des'];
							   }
							   
							}else{
								$return['valid'] = false;
								$return['status_code'] = 501;
					         	$return['message'] = 'No result2';
							}
							//return['valid'] = $result['valid'];
							//return['status_code'] = $result['no'];
							//return['message'] = $result['des'];
						}
						
						//proses approve warehouse
						
						
					} else {
						$return['status_code'] = $result['no'];
						$return['message'] = $result['des'];
					}
				}
			 }
			
			
		} else {
			$return['valid'] = false;
			$return['message'] = "Session expired";
		}
		
		echo json_encode($return);
	}
	
