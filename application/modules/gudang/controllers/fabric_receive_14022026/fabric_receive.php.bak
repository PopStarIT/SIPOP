		//var_dump($q);die();
		//die();
		if (count($_POST) > 0) {
			// if($code_barcode ==''){
			if ($q == 0) {
				//  var_dump($fabric_shipment_list_id);die();
				$this->rpc_service->setSP("dbo.sp_fabric_receive_scan_add_manual");
				$this->rpc_service->addField('fabric_shipment_list_id', $fabric_shipment_list_id);
