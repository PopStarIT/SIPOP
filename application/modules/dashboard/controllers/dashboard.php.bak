<?php if ( ! defined('BASEPATH')) exit('No direct script access allowed');
Class Dashboard extends CI_Controller { 
	function __construct()	{ 
		parent::__construct();       // var_dump($method = $this->router->method);		       				$this->data_request = $_REQUEST;				$module = $this->router->module;		$directory = $this->router->directory;		$class = $this->router->class;		$method = $this->router->method;		$directory = trim(str_replace('../modules/'.$module ,'',str_replace('/controllers/','',$directory)),'/');		//var_dump($directory);		$this->module = $module;		if(trim($directory) != ''){			$this->directory = $directory;		} else {			$this->directory = '0';			$this->directory2 = '';		}		$this->class = $class;		$this->method = $method;		
	} 
      function tabel_jml_tanggal_prod_transfer_lebih(){		$field = array();		$field['r1'] = array('sc' => 'r1','ctype' => 'text', 'bypassvalue' => '', 'title' => 'TRANSFER ID');		$field['r2'] = array('sc' => 'r2','ctype' => 'text', 'bypassvalue' => '', 'title' => 'DOK FROM');		$field['r3'] = array('sc' => 'r3','ctype' => 'text', 'bypassvalue' => '', 'title' => 'TRANSFER NO');		$field['r4'] = array('sc' => 'r4','ctype' => 'date', 'bypassvalue' => '', 'title' => 'TRANSFER DATE');		$field['r5'] = array('sc' => 'r5','ctype' => 'date', 'bypassvalue' => '', 'title' => 'STOCK MOVE DATE');		$field['r6'] = array('sc' => 'r6','ctype' => 'time', 'bypassvalue' => '', 'title' => 'KODE BARANG');		$field['r7'] = array('sc' => 'r7','ctype' => 'text', 'bypassvalue' => '', 'title' => 'QTY REQUEST');		$field['r8'] = array('sc' => 'r8','ctype' => 'text', 'bypassvalue' => '', 'title' => 'QTY SUPPLY');		return $field;	  }
		function index(){				//echo 'kesini';		$this->load->model('main');		$this->load->model('main_sipop');		//$this->CI->load->model('main');								$component['loadlayout'] = true;		$component['view_load'] = 'monitor/view';		$component['load_js'][] = 'monitor/view';				//$component['view_load'] = 'monitoringxx';				$component['page_title'] = "Dashboard";				$dashboard_tab = array();		//$tab_production = array('alias' => 'Production', 'title' => 'Monitor', 'icon' => 'fa fa-list');		$tab_error = array('alias' => 'error', 'title' => 'Data Report', 'icon' => 'fa fa-address-card');		$tab_monitor = array('alias' => 'monitor', 'title' => 'Manufacture', 'icon' => 'fa fa-list');			//	$tab_Request_content = array();	//	//$tab_Request_content[] = array('method_id' => 781044, 'menu_name' => 'Production Request', 'menu_icon' => 'fa fa-user-circle-o'); //fa fa-address-book  //104	//	$tab_Request_content[] = array('method_id' => 7811208, 'menu_name' => 'Production Request', 'menu_icon' => 'fa fa-user-circle-o'); //fa fa-address-book  //104	//		//	$tab_content_error = array();	//	$tab_content_error[] = array('method_id' => 7811208, 'menu_name' => 'Production Requestxxxx', 'menu_icon' => 'fa fa-user-circle-o'); //fa fa-address-book  //104	//		//	$tab_error['content'] = $tab_content_error;	//	$tab_Request['content'] = $tab_Request_content;						$date_start2 = date("Y-m-d");		$date_start = date('Y-m-d', strtotime(' -4 day'));		//echo $date_start;		//$date_end = date("Y-m-d");		$date_start3 = '2025-01-01';		$kode='FB';		$cek= $this->main->jumlah_prod_request($date_start);		//$total = $this->main->countData_pop2('dbo.view_nomor_prod_request',array('work_order_request_date=>"'.$date_start.'"','kode =>'.$kode),null);		//$total = $this->main->countData_pop2('dbo.view_nomor_prod_request',array(['work_order_request_date']=>$date_start,['kode']=>$kode),null);		$total_fb = $this->main->jumlah_prod_request_item($date_start,'kode =',$kode);		$total_other = $this->main->jumlah_prod_request_item($date_start,'kode !=',$kode);		//$total = $this->main->countData_pop($table, $where = null, $group = null)				$date_start_report = date('Y-m-d', strtotime(' -30 day'));		$date_end_report = date("Y-m-d");		//echo $date_end_report;		$total_error_report_bahan_baku = $this->main_sipop->error_bahan_baku($date_start_report,$date_end_report);		$jml_dok_bc_supply_kosong = $this->main_sipop->jml_dok_bc_supply_kosong($date_start_report,$date_end_report);		$jml_tanggal_prod_transfer_lebih = $this->main_sipop->jml_tanggal_prod_transfer_lebih($date_start_report);		$jml_beda_kode_barang_supply_transfer = $this->main_sipop->jml_beda_kode_barang_supply_transfer($date_start_report);				$component['total_request'] = $cek[0]['count'];			$component['total_request_fb'] = $total_fb[0]['count'];			$component['total_request_other'] = $total_other[0]['count'];					$component['error_report_bahan_baku'] = $total_error_report_bahan_baku[0]['minus_bahan_baku'];		$component['jml_dok_bc_supply_kosong'] = $jml_dok_bc_supply_kosong[0]['count'];		$component['jml_tanggal_prod_transfer_lebih'] = $jml_tanggal_prod_transfer_lebih[0]['count'];		$component['jml_beda_kode_barang_supply_transfer'] =$jml_beda_kode_barang_supply_transfer[0]['count'];				//$tab_purchase_content = array();		//$tab_purchase_content[] = array('method_id' => 104, 'menu_name' => 'Report', 'menu_icon' => 'fa fa-table');				//$tab_production['content'] = $tab_purchase_content;				$dashboard_tab[] = $tab_error;		$dashboard_tab[] = $tab_monitor;				//$dashboard_tab[] = $tab_error;				$component['dashboard_tab'] = $dashboard_tab;							$this->authentication->ajaxlayout($component);	}		function index_awal(){		//var_dump("dash ");		$component['loadlayout'] = true;		$component['view_load'] = 'monitoring';				$dashboard_tab = array();				$tab_production = array('alias' => 'Production', 'title' => 'Production', 'icon' => 'fa fa-list');		//$tab_purchase_invoice = array('alias' => 'Tracing', 'title' => 'Payrol', 'icon' => 'fa fa-exchange');				$tab_purchase_content = array();		$tab_purchase_content[] = array('method_id' => 104, 'menu_name' => 'Report', 'menu_icon' => 'fa fa-table');		$tab_purchase_content[] = array('method_id' => 105, 'menu_name' => 'Penelusuran', 'menu_icon' => 'fa fa-arrows');		//$tab_purchase_content[] = array('method_id' => 106, 'menu_name' => 'Memo Purchase', 'menu_icon' => 'fa fa-users');		//$tab_purchase_content[] = array('method_id' => 918, 'menu_name' => 'Monitoring PO', 'menu_icon' => 'fa fa-users');		$tab_production['content'] = $tab_purchase_content;				//$tab_purchase_invoice_content = array();		//$tab_purchase_invoice_content[] = array('method_id' => 160, 'menu_name' => 'Proforma Invoice', 'menu_icon' => 'fa fa-external-link');		//$tab_purchase_invoice['content'] = $tab_purchase_invoice_content;					$dashboard_tab[] = $tab_production;		//$dashboard_tab[] = $tab_purchase_invoice;					$component['dashboard_tab'] = $dashboard_tab;						$this->authentication->ajaxlayout($component);	}		function loaddata_jml_tanggal_prod_transfer_lebih(){				$tabel_jml_tanggal_prod_transfer_lebih = $this->tabel_jml_tanggal_prod_transfer_lebih();	    $this->load->model('main');				$date_start = isset($_REQUEST['date_start']) ? $_REQUEST['date_start'] : '';		$date_end = isset($_REQUEST['date_end']) ? $_REQUEST['date_end'] : '';		$print = isset($_REQUEST['print']) ? $_REQUEST['print'] : 0;		$format = isset($_REQUEST['format']) ? $_REQUEST['format'] : 'xlsx';		$page = isset($_POST['page'])?$_POST['page']:1; // get the requested page         $rows = isset($_POST['rows'])?$_POST['rows']:10; // get how many rows we want to have into the grid         $sidx = isset($_POST['sidx'])?$_POST['sidx']:'r2'; // get index row - i.e. user click to sort         $sord = isset($_POST['sord'])?$_POST['sord']:'0'; // get the direction 		$search = isset($_REQUEST['_search'])?$_REQUEST['_search']:false; 		$filterRules =  isset($_POST['filters'])?$_POST['filters']:false;     }		function preview_dashboard2(){		 $component['loadlayout'] = true;		 $component['view_load'] = 'monitor/dashboard';		 $component['load_js'][] = 'monitor/view';				 $this->db_pop = $this->load->database('pop',TRUE);		 $this->load->model('main');		 $this->load->model('main_sipop');		// $purchase_order_id = (isset($_GET['purchase_order_id']) && !empty($_GET['purchase_order_id']))?$_GET['purchase_order_id']:die('{"sts":"ERROR","desc":" Param Header Tidak Ditemukan"}');		 $component['methodid'] = isset($_GET['methodid']) ? is_numeric($_GET['methodid']) ? $_GET['methodid']  : -1 : -1;				//$component['view_load'] = 'dashboard';		//$component['load_js'][] = 'dashboard';				 $date_start_report = date('Y-m-d', strtotime(' -30 day'));		 $jml_tanggal_prod_transfer_lebih = $this->main_sipop->jml_tanggal_prod_transfer_lebih($date_start_report);		 $jml_beda_kode_barang_supply_transfer = $this->main_sipop->jml_beda_kode_barang_supply_transfer($date_start_report);		 		 $component['jml_tanggal_prod_transfer_lebih'] = $jml_tanggal_prod_transfer_lebih[0]['count'];		 $component['jml_beda_kode_barang_supply_transfer'] = $jml_beda_kode_barang_supply_transfer[0]['count'];			// var_dump($component);die();		 $this->authentication->ajaxlayout($component);	    // $this->authentication->layout_dashboard_preview($component);		//$this->load->view('draft/preview_dashboard/dashboard',$component);	}		function preview_dashboard(){		// $data['view_load'] = 'monitor/view';		// $data['load_js'][] = 'monitor/view';				 $this->db_pop = $this->load->database('pop',TRUE);		 $this->load->model('main');		 $this->load->model('main_sipop');		// $purchase_order_id = (isset($_GET['purchase_order_id']) && !empty($_GET['purchase_order_id']))?$_GET['purchase_order_id']:die('{"sts":"ERROR","desc":" Param Header Tidak Ditemukan"}');		 $data['methodid'] = isset($_GET['methodid']) ? is_numeric($_GET['methodid']) ? $_GET['methodid']  : -1 : -1;		//$component['loadlayout'] = true;		//$component['view_load'] = 'dashboard';		//$component['load_js'][] = 'dashboard';		//$component['view_load'] = 'monitor/view';		//$component['load_js'][] = 'monitor/view';		 $date_start_report = date('Y-m-d', strtotime(' -30 day'));		 $jml_tanggal_prod_transfer_lebih = $this->main_sipop->jml_tanggal_prod_transfer_lebih($date_start_report);		 $jml_beda_kode_barang_supply_transfer = $this->main_sipop->jml_beda_kode_barang_supply_transfer($date_start_report);		 		 $data['jml_tanggal_prod_transfer_lebih'] = $jml_tanggal_prod_transfer_lebih[0]['count'];		 $data['jml_beda_kode_barang_supply_transfer'] = $jml_beda_kode_barang_supply_transfer[0]['count'];			// var_dump($path_template);	  // $this->authentication->blanklayout($component);		$this->load->view('draft/preview_dashboard/dashboard',$data);	}		
}