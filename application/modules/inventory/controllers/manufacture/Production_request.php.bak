<?php if ( ! defined('BASEPATH')) exit('No direct script access allowed');Class Production_request extends CI_Controller { 	function __construct(){ 		parent::__construct(); 				$this->data_production = $_REQUEST;				$module = $this->router->module;		$directory = $this->router->directory;		$class = $this->router->class;		$method = $this->router->method;		$directory = trim(str_replace('../modules/'.$module ,'',str_replace('/controllers/','',$directory)),'/');				$this->module = $module;		if(trim($directory) != ''){			$this->directory = $directory;		} else {			$this->directory = '0';			$this->directory2 = '';		}		$this->class = $class;		$this->method = $method;	}		function work_order_request_table() {		$view = 'view_work_order_request';		$get_field = $this->ecc_library->get_field($view);				$get_field['r1']['hidden'] = true;		$get_field['r9']['hidden'] = true;		$get_field['r11']['hidden'] = true;		$get_field['r12']['hidden'] = true;						return $get_field;	}		function work_order_request_detail_table() {		$view = 'view_work_order_request_detail';		$get_field = $this->ecc_library->get_field($view);				$get_field['r1']['hidden'] = true;		$get_field['r2']['hidden'] = true;		$get_field['r7']['hidden'] = true;				$get_field['act']['sc'] = 'act';		$get_field['act']['title'] = '#';		$get_field['act']['bypassvalue'] = '';		$get_field['act']['ctype'] = 'text';		$get_field['act']['align'] = 'center';		$get_field['act']['search'] = false;		$get_field['act']['sortable'] = false;		$get_field['act']['formatter'] = 'formatOperations';		$get_field['act']['width'] = 300;				return $get_field;	}		function work_order_request_transfer_item_table() {		$view = 'view_stock_move_item_work_order_request';		$get_field = $this->ecc_library->get_field($view);		$get_field['r1']['hidden'] = true;		$get_field['r12']['hidden'] = true;				return $get_field;	}		function index(){		$this->load->model('main');		$component['loadlayout'] = true;		$component['view_load'] = 'manufacture/production_request/view';		$component['view_load_form'] = 'manufacture/production_request/form';		$component['load_js'][] = 'manufacture/production_request/view';		$component['load_js'][] = 'manufacture/production_request/form';				$component['page_title'] = "Production Request";				$dashboard_table = array();				$nav_button = array();		$nav_button[] = array('method_id' => 618,'title' => 'Add', 'icon' => 'fa fa-plus', 'load' => 'manufacture/production_request/function_add');		$nav_button[] = array('method_id' => 619,'title' => 'Edit', 'icon' => 'fa fa-pencil', 'load' => 'manufacture/production_request/function_edit');		$nav_button[] = array('method_id' => 622,'title' => 'Approve', 'icon' => 'fa fa-pencil', 'load' => 'manufacture/production_request/function_approve');		$nav_button[] = array('method_id' => 621,'title' => 'Delete', 'icon' => 'fa fa-trash-o', 'load' => 'manufacture/production_request/function_delete');		//$nav_button[] = array('method_id' => 758,'title' => 'Cancel Approve', 'icon' => 'fa fa-cross', 'load' => 'manufacture/production_request/function_cancel_approve');		$nav_button[] = array('method_id' => 772,'title' => 'Cancel Approve', 'icon' => 'fa fa-cross', 'load' => 'manufacture/production_request/function_cancel_approve');		//===772		$nav_button[] = array('method_id' => 803,'title' => 'Print', 'icon' => 'fa fa-print', 'load' => 'manufacture/production_request/function_print');				$field = $this->work_order_request_table();		$field_detail = $this->work_order_request_detail_table();		$field_transfer_item = $this->work_order_request_transfer_item_table();				$dashboard_table['nav_button'] = $nav_button;		$dashboard_table['field'] = $field;		$dashboard_table['field_detail'] = $field_detail;		$dashboard_table['field_detail_loaddata'] = 'loaddata_detail';		$dashboard_table['field_transfer_item'] = $field_transfer_item;		$dashboard_table['field_transfer_item_loaddata'] = 'loaddata_transfer_item';				$component['dashboard_table'] = $dashboard_table;				$this->authentication->ajaxlayout($component);	}		function loaddata() {		$this->authentication->plainlayout();				$view = 'view_work_order_request';		$field = $this->work_order_request_table();				$return = array();		$return['valid'] = false;		$return['message'] = "Internal Server Error"; 		$loaddata = $this->ecc_library->get_field_data($view,$field);					echo $loaddata;	}		function approve(){		$this->authentication->plainlayout();		$parameter = array();		$return = array();						$work_order_request_id = isset($_POST['work_order_request_id']) ? $_POST['work_order_request_id'] : false;				$user_id = $this->session->userdata('user_id');				$result = array();		$return['valid'] = false;		$return['status_code'] = 501;		$return['message'] = "Internal Server Error";				if(count($_POST) > 0){						if($work_order_request_id){				$this->rpc_service->setSP("dbo.sp_work_order_request_approve");				$this->rpc_service->addField('work_order_request_id',$work_order_request_id);			}								$result = $this->rpc_service->resultJSON();			// print_r($result);						$data = array();			if(isset($result)){				if(isset($result['valid'])){					if($result['valid']){						if(isset($result['data'])){							$return['valid'] = $result['valid'];							$return['status_code'] = $result['no'];							$return['message'] = $result['des'];						}					} else {						$return['status_code'] = $result['no'];						$return['message'] = $result['des'];					}				}			}					} else {			$return['valid'] = false;			$return['message'] = "Session expired";		}				echo json_encode($return);	}		function cancel_approve(){		$this->authentication->plainlayout();		$parameter = array();		$return = array();						$work_order_request_id = isset($_POST['work_order_request_id']) ? $_POST['work_order_request_id'] : false;				$user_id = $this->session->userdata('user_id');				$result = array();		$return['valid'] = false;		$return['status_code'] = 501;		$return['message'] = "Internal Server Error";				if(count($_POST) > 0){						if($work_order_request_id){				$this->rpc_service_portal->setSP("dbo.sp_work_order_request_cancel_approve");				$this->rpc_service_portal->addField('work_order_request_id',$work_order_request_id);			}								$result = $this->rpc_service_portal->resultJSON();			// print_r($result);						$data = array();			if(isset($result)){				if(isset($result['valid'])){					if($result['valid']){						if(isset($result['data'])){							$return['valid'] = $result['valid'];							$return['status_code'] = $result['no'];							$return['message'] = $result['des'];						}					} else {						$return['status_code'] = $result['no'];						$return['message'] = $result['des'];					}				}			}					} else {			$return['valid'] = false;			$return['message'] = "Session expired";		}				echo json_encode($return);	}			function delete(){		$this->authentication->plainlayout();		$parameter = array();		$return = array();						$work_order_request_id = isset($_POST['work_order_request_id']) ? $_POST['work_order_request_id'] : false;				$user_id = $this->session->userdata('user_id');				$result = array();		$return['valid'] = false;		$return['status_code'] = 501;		$return['message'] = "Internal Server Error";				if(count($_POST) > 0){						if($work_order_request_id){				$this->rpc_service->setSP("dbo.sp_work_order_request_delete");				$this->rpc_service->addField('work_order_request_id',$work_order_request_id);			}								$result = $this->rpc_service->resultJSON();			// print_r($result);						$data = array();			if(isset($result)){				if(isset($result['valid'])){					if($result['valid']){						if(isset($result['data'])){							$return['valid'] = $result['valid'];							$return['status_code'] = $result['no'];							$return['message'] = $result['des'];						}					} else {						$return['status_code'] = $result['no'];						$return['message'] = $result['des'];					}				}			}					} else {			$return['valid'] = false;			$return['message'] = "Session expired";		}				echo json_encode($return);	}		function post_add_edit(){		$this->authentication->plainlayout();		$parameter = array();		$return = array();										$work_order_request_id = isset($_POST['work_order_request_id']) ? $_POST['work_order_request_id'] : '';		$work_order_request_no = isset($_POST['work_order_request_no']) ? $_POST['work_order_request_no'] : '';		$work_order_request_date = isset($_POST['work_order_request_date']) ? $_POST['work_order_request_date'] : '';		$work_order_plan_id = isset($_POST['work_order_plan_id']) ? $_POST['work_order_plan_id'] : '';					$user_id = $this->session->userdata('user_id');				$result = array();		$return['valid'] = false;		$return['status_code'] = 501;		$return['message'] = "Internal Server Error";				if(count($_POST) > 0){			if($work_order_request_id){				$this->rpc_service->setSP("dbo.sp_work_order_request_edit");				$this->rpc_service->addField('work_order_request_id',$work_order_request_id);			} else {				$this->rpc_service->setSP("dbo.sp_work_order_request_add");			}						$this->rpc_service->addField('work_order_request_no',$work_order_request_no);			$this->rpc_service->addField('work_order_request_date',$work_order_request_date);			$this->rpc_service->addField('work_order_plan_id',$work_order_plan_id);									$result = $this->rpc_service->resultJSON();									$data = array();			if(isset($result)){				if(isset($result['valid'])){					if($result['valid']){						if(isset($result['data'])){							$data = json_decode($result['data'],TRUE);							$work_order_request_id = $data['work_order_request_id'];														$return['valid'] = $result['valid'];							$return['status_code'] = $result['no'];							$return['message'] = $result['des'];							$return['work_order_request_id'] = $work_order_request_id;						}					} else {						$return['status_code'] = $result['no'];						$return['message'] = $result['des'];					}				}			}					} else {			$return['valid'] = false;			$return['message'] = "Session expired";		}				echo json_encode($return);	}		function loaddata_detail(){		$this->authentication->plainlayout();				$work_order_request_id = isset($_REQUEST['work_order_request_id']) ? is_numeric($_REQUEST['work_order_request_id']) ? $_REQUEST['work_order_request_id']  : -1 : -1;		$methodid = isset($_REQUEST['methodid']) ? is_numeric($_REQUEST['methodid']) ? $_REQUEST['methodid']  : -1 : -1;				$view = 'view_work_order_request_detail';		$field = $this->work_order_request_detail_table();				$return = array();		$return['valid'] = false;		$return['message'] = "Internal Server Error";				$extra_param = array();		$extra_param['where']['0']['field'] = 'r2';		$extra_param['where']['0']['data'] = $work_order_request_id;		$extra_param['methodid'] = $methodid;				$loaddata = $this->ecc_library->get_field_data($view,$field,$extra_param);					echo $loaddata;	}			function post_add_edit_detail(){		$this->authentication->plainlayout();		$parameter = array();		$return = array();				$work_order_request_detail_id = isset($_POST['work_order_request_detail_id']) ? $_POST['work_order_request_detail_id'] : false;		$work_order_request_id = isset($_POST['work_order_request_id']) ? $_POST['work_order_request_id'] : false;		$item_id = isset($_POST['item_id']) ? $_POST['item_id'] : '';		$work_order_request_item_id = isset($_POST['work_order_request_item_id']) ? $_POST['work_order_request_item_id'] : '';		$quantity_work_order_request = isset($_POST['quantity_work_order_request']) ? $_POST['quantity_work_order_request'] : '';		$user_id = $this->session->userdata('user_id');						$result = array();		$return['valid'] = false;		$return['status_code'] = 501;		$return['message'] = "Internal Server Error";				if(count($_POST) > 0){			if($work_order_request_detail_id){				$this->rpc_service->setSP("dbo.sp_work_order_request_detail_edit");				$this->rpc_service->addField('work_order_request_detail_id',$work_order_request_detail_id);			} else {				$this->rpc_service->setSP("dbo.sp_work_order_request_detail_add");			}						$this->rpc_service->addField('work_order_request_id',$work_order_request_id);			$this->rpc_service->addField('item_id',$item_id);			$this->rpc_service->addField('work_order_request_item_id',$work_order_request_item_id);			$this->rpc_service->addField('quantity_work_order_request',$quantity_work_order_request);						$result = $this->rpc_service->resultJSON();						$data = array();			if(isset($result)){				if(isset($result['valid'])){					if($result['valid']){						if(isset($result['data'])){														$return['valid'] = $result['valid'];							$return['status_code'] = $result['no'];							$return['message'] = $result['des'];												}					} else {						$return['status_code'] = $result['no'];						$return['message'] = $result['des'];					}				}			}					} else {			$return['valid'] = false;			$return['message'] = "Session expired";		}				echo json_encode($return);	}		function loaddata_detail_total(){		$this->authentication->plainlayout();				$field = array();		$field[] = array('field' => 'item', 'title' => 'item');		$field[] = array('field' => 'quantity_requirement', 'title' => 'unit');		$field[] = array('field' => 'uom_code', 'title' => 'mat_quantity');		$field[] = array('field' => 'fg_item', 'title' => 'mat_quantity');		$field[] = array('field' => 'quantity_work_order_request', 'title' => 'mat_quantity');			$new_work_order_request = isset($_POST['new_work_order_request']) ? $_POST['new_work_order_request'] : 0;		$work_order_request_id = isset($_POST['work_order_request_id']) ? is_numeric($_POST['work_order_request_id']) ? $_POST['work_order_request_id'] : -1: -1;		$return = array();		$return['valid'] = false;		$return['message'] = "Internal Server Error";		$loaddata_table = array();						$view = 'dbo.view_work_order_request_detail';		$where = array();		$where['work_order_request_id'] = $work_order_request_id;		$loaddata = $this->ecc_library->loaddata($view,$field, $where);					foreach($loaddata['data'] as $key => $value){						$new_row = array();			$new_row[] = $value[0];			$new_row[] = $this->mainconfig->get_decimal_format($value[1],12);			$new_row[] = $value[2];			$new_row[] = $value[3];			$new_row[] = $this->mainconfig->get_decimal_format($value[4],12);										$loaddata_table[$value[0]] = $new_row;		}								$loaddata['data'] = array();		foreach($loaddata_table as $value){						$data = array();			$data[] = $value[0];			$data[] = $value[1];			$data[] = $value[2];			$data[] = $value[3];			$data[] = $value[4];						$loaddata['data'][] = $data;		}				echo json_encode($loaddata);	}		function delete_detail(){		$this->authentication->plainlayout();		$parameter = array();		$return = array();				$result = array();		$return['valid'] = false;		$return['status_code'] = 501;		$return['message'] = "Internal Server Error";				$work_order_request_detail_id = isset($_POST['work_order_request_detail_id']) ? $_POST['work_order_request_detail_id'] : '';		$user_id = $this->session->userdata('user_id');				if(count($_POST) > 0){						if($work_order_request_detail_id){				$this->rpc_service->setSP("dbo.sp_work_order_request_detail_delete");				$this->rpc_service->addField('work_order_request_detail_id',$work_order_request_detail_id);			}								$result = $this->rpc_service->resultJSON();			// print_r($result);						$data = array();			if(isset($result)){				if(isset($result['valid'])){					if($result['valid']){						if(isset($result['data'])){							$return['valid'] = $result['valid'];							$return['status_code'] = $result['no'];							$return['message'] = $result['des'];						}					} else {						$return['status_code'] = $result['no'];						$return['message'] = $result['des'];					}				}			}					} else {			$return['valid'] = false;			$return['message'] = "Session expired";		}				echo json_encode($return);	}		function loaddata_transfer_item(){		$this->authentication->plainlayout();				$work_order_request_detail_id = isset($_REQUEST['work_order_request_detail_id']) ? is_numeric($_REQUEST['work_order_request_detail_id']) ? $_REQUEST['work_order_request_detail_id']  : -1 : -1;		$methodid = isset($_REQUEST['methodid']) ? is_numeric($_REQUEST['methodid']) ? $_REQUEST['methodid']  : -1 : -1;				$view = 'view_stock_move_item_work_order_request';		$field = $this->work_order_request_transfer_item_table();				$return = array();		$return['valid'] = false;		$return['message'] = "Internal Server Error";				$extra_param = array();		$extra_param['where']['0']['field'] = 'r12';		$extra_param['where']['0']['data'] = $work_order_request_detail_id;		$extra_param['methodid'] = $methodid;				$loaddata = $this->ecc_library->get_field_data($view,$field,$extra_param);					echo $loaddata;	}		function print_production_request()   {      $work_order_request_id = isset($_POST['work_order_request_id']) ? $_POST['work_order_request_id'] : false;      // $kepada = isset($_POST['kepada']) ? $_POST['kepada'] : false;      // $no_ws = isset($_POST['no_ws']) ? $_POST['no_ws'] : false;      // $keterangan = isset($_POST['keterangan']) ? $_POST['keterangan'] : false;      $format = isset($_POST['format']) ? $_POST['format'] : 'xlsx';      $user_id = $this->session->userdata('user_id');           $sp = "dbo.sp_rpt_slip_production_request";           $this->rpc_service_portal->setSP(array("sp"=>$sp,"mode"=>"2","debug"=>"1"));      $this->rpc_service_portal->addField('work_order_request_id',$work_order_request_id);      // $this->rpc_service_portal->addField('kepada',$kepada);      // $this->rpc_service_portal->addField('no_ws',$no_ws);      // $this->rpc_service_portal->addField('keterangan',$keterangan);      $this->rpc_service_portal->addField('format',$format);      $this->rpc_service_portal->addField('temp_folder',sys_get_temp_dir());      $this->rpc_service_portal->addField('sort','dt_mst_item.item_code asc');              $result = $this->rpc_service_portal->resultPrint2();      echo json_encode($result);   }	}?>