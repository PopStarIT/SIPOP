<?php if ( ! defined('BASEPATH')) exit('No direct script access allowed');
Class Subcon extends CI_Controller { 
	function __construct(){ 		parent::__construct(); 				$this->data_request = $_REQUEST;				$module = $this->router->module;		$directory = $this->router->directory;		$class = $this->router->class;		$method = $this->router->method;		$directory = trim(str_replace('../modules/'.$module ,'',str_replace('/controllers/','',$directory)),'/');				$this->module = $module;		if(trim($directory) != ''){			$this->directory = $directory;		} else {			$this->directory = '0';			$this->directory2 = '';		}		$this->class = $class;		$this->method = $method;	}		function contract_subcon_table() {		$view = 'view_contract_subcon';		$get_field = $this->ecc_library->get_field($view);				$get_field['r1']['hidden'] = true;		$get_field['r12']['hidden'] = true;		$get_field['r13']['hidden'] = true;		$get_field['r14']['hidden'] = true;		$get_field['r15']['hidden'] = true;		$get_field['r16']['hidden'] = true;		$get_field['r17']['hidden'] = true;		$get_field['r18']['hidden'] = true;		$get_field['r19']['hidden'] = true;		$get_field['r20']['hidden'] = true;								$get_field['r2']['width'] = 250;		$get_field['r3']['width'] = 200;				$get_field['r4']['title'] = "Contract Subcon Date";		$get_field['r4']['width'] = 250;				$get_field['r6']['width'] = 250;		$get_field['r7']['width'] = 250;				return $get_field;	}	function monitor_contract_table() {		$view = 'view_work_order_monitoring_contract_subcon';		$get_field = $this->ecc_library->get_field_pop($view);				$get_field['r1']['hidden'] = true;				$get_field['r8']['footer'] = 'Total Quantity :';		$get_field['r9']['footer'] = 'sum';				return $get_field;	}		function monitor_contract_table_peritem() {		$view = 'view_work_order_monitoring_contrat_per_item';		$get_field = $this->ecc_library->get_field_pop($view);				$get_field['r1']['hidden'] = true;		$get_field['r2']['hidden'] = true;		$get_field['r3']['hidden'] = true;				return $get_field;	}		function index(){		$this->load->model('main');		$component['loadlayout'] = true;		$component['view_load'] = 'subcon/subcon/view';		$component['view_load_form'] = 'subcon/subcon/form';		$component['load_js'][] = 'subcon/subcon/view';		$component['load_js'][] = 'subcon/subcon/form';				$component['page_title'] = "Contract Subcon";		$dashboard_table = array();				$nav_button = array();		$nav_button[] = array('method_id' => 123,'title' => 'Add', 'icon' => 'fa fa-plus', 'load' => 'subcon/subcon/function_add');		$nav_button[] = array('method_id' => 171,'title' => 'Edit', 'icon' => 'fa fa-pencil', 'load' => 'subcon/subcon/function_edit');		$nav_button[] = array('method_id' => 435,'title' => 'Approve', 'icon' => 'fa fa-check', 'load' => 'subcon/subcon/function_approve');		$nav_button[] = array('method_id' => 364,'title' => 'Delete', 'icon' => 'fa fa-trash-o', 'load' => 'subcon/subcon/function_delete');		$nav_button[] = array('method_id' => 787,'title' => 'Cancel Approve', 'icon' => 'fa fa-check', 'load' => 'subcon/subcon/function_cancel_approve');		$nav_button[] = array('method_id' => 781104,'title' => 'Monitoring Contract', 'icon' => 'fa fa-pencil', 'load' => 'subcon/subcon/function_monitoring_contract');		//781104		$field = $this->contract_subcon_table();				$dashboard_table['nav_button'] = $nav_button;		$dashboard_table['field'] = $field;				$component['dashboard_table'] = $dashboard_table;				$this->authentication->ajaxlayout($component);	}		function loaddata()   {		$this->authentication->plainlayout();				$view = 'view_contract_subcon';		$field = $this->contract_subcon_table();				$return = array();		$return['valid'] = false;		$return['message'] = "Internal Server Error"; 		$loaddata = $this->ecc_library->get_field_data($view,$field);					echo $loaddata;	}		function loaddata_cek_qty_contract(){		$this->authentication->plainlayout();		$this->load->model('main');		$work_order_contract_id = isset($_POST['work_order_contract_id']) ? $_POST['work_order_contract_id'] :'';		$jml_qty=$this->main->total_contract_subcon($work_order_contract_id);		$jml_qty['hasil']=number_format($jml_qty[0]['sum'],4);		//var_dump ($jml_qty[0]['sum']);		echo json_encode($jml_qty);		//echo $jml_qty;	}		function loaddata_monitor_contract(){		$this->authentication->plainlayout();		$this->load->model('main');				$work_order_contract_id = isset($_POST['work_order_contract_id']) ? $_POST['work_order_contract_id'] :'';		$methodid = isset($_REQUEST['methodid']) ? is_numeric($_REQUEST['methodid']) ? $_REQUEST['methodid']  : -1 : -1;				$view = 'view_work_order_monitoring_contract_subcon';		$field = $this->monitor_contract_table();				$jml_qty=$this->main->total_contract_subcon($work_order_contract_id);		//$jml_perbarang=$this->main->total_subcon_perdetail($work_order_contract_id);		//var_dump($jml_perbarang);				$return = array();		$return['valid'] = false;		$return['message'] = "Internal Server Error";				$extra_param = array();		$extra_param['jml_qty'] = $jml_qty[0]['sum'];		$extra_param['where']['0']['field'] = 'r1';		$extra_param['where']['0']['data'] = $work_order_contract_id;		$extra_param['methodid'] = $methodid;		$extra_param['footer_data'] = true;		$extra_param['sp_sum'] ='dbo.sp_monitor_contract_sum';		//$extra_param['sp_sum'] = 'dbo.sp_assets_incoming_sum';				$loaddata = $this->ecc_library->get_field_data_pop($view,$field,$extra_param);		//total_qty_contract		//var_dump($loaddata);		//$qtyContract = json_decode($loaddata);       // echo $qtyContract->total_qty_contract;		//print_r ($loaddata);		echo $loaddata;	}		function loaddata_monitor_jml_per_item(){		$this->authentication->plainlayout();		$this->load->model('main');				$work_order_contract_id = isset($_POST['work_order_contract_id']) ? $_POST['work_order_contract_id'] :'';		$methodid = isset($_REQUEST['methodid']) ? is_numeric($_REQUEST['methodid']) ? $_REQUEST['methodid']  : -1 : -1;				$view = 'view_work_order_monitoring_contrat_per_item';		$field = $this->monitor_contract_table_peritem();				//$jml_qty=$this->main->total_contract_subcon($work_order_contract_id);		//$jml_perbarang=$this->main->total_subcon_perdetail($work_order_contract_id);		//var_dump($work_order_contract_id);				$return = array();		$return['valid'] = false;		$return['message'] = "Internal Server Error";				$extra_param = array();		//$extra_param['jml_qty'] = $jml_qty[0]['sum'];		$extra_param['where']['0']['field'] = 'r1';		$extra_param['where']['0']['data'] = $work_order_contract_id;		$extra_param['methodid'] = $methodid;				$loaddata = $this->ecc_library->get_field_data_pop($view,$field,$extra_param);		//total_qty_contract		//var_dump($loaddata['total_qty_contract']);		//$qtyContract = json_decode($loaddata);       // echo $qtyContract->total_qty_contract;		//print_r ($loaddata);		echo $loaddata;	}		function approve(){		$this->authentication->plainlayout();		$parameter = array();		$return = array();						$contract_subcon_id = isset($_POST['contract_subcon_id']) ? $_POST['contract_subcon_id'] : false;				$user_id = $this->session->userdata('user_id');				$result = array();		$return['valid'] = false;		$return['status_code'] = 501;		$return['message'] = "Internal Server Error";				if(count($_POST) > 0){						if($contract_subcon_id){				$this->rpc_service->setSP("dbo.sp_contract_subcon_approve");				$this->rpc_service->addField('contract_subcon_id',$contract_subcon_id);			}								$result = $this->rpc_service->resultJSON();			// print_r($result);						$data = array();			if(isset($result)){				if(isset($result['valid'])){					if($result['valid']){						if(isset($result['data'])){							$return['valid'] = $result['valid'];							$return['status_code'] = $result['no'];							$return['message'] = $result['des'];						}					} else {						$return['status_code'] = $result['no'];						$return['message'] = $result['des'];					}				}			}					} else {			$return['valid'] = false;			$return['message'] = "Session expired";		}				echo json_encode($return);	}		function cancel_approve(){		$this->authentication->plainlayout();		$parameter = array();		$return = array();						$contract_subcon_id = isset($_POST['contract_subcon_id']) ? $_POST['contract_subcon_id'] : false;				$user_id = $this->session->userdata('user_id');				$result = array();		$return['valid'] = false;		$return['status_code'] = 501;		$return['message'] = "Internal Server Error";				if(count($_POST) > 0){						if($contract_subcon_id){				$this->rpc_service->setSP("dbo.sp_contract_subcon_cancel_approve");				$this->rpc_service->addField('contract_subcon_id',$contract_subcon_id);			}								$result = $this->rpc_service->resultJSON();			// print_r($result);						$data = array();			if(isset($result)){				if(isset($result['valid'])){					if($result['valid']){						if(isset($result['data'])){							$return['valid'] = $result['valid'];							$return['status_code'] = $result['no'];							$return['message'] = $result['des'];						}					} else {						$return['status_code'] = $result['no'];						$return['message'] = $result['des'];					}				}			}					} else {			$return['valid'] = false;			$return['message'] = "Session expired";		}				echo json_encode($return);	}		function delete(){		$this->authentication->plainlayout();		$parameter = array();		$return = array();						$contract_subcon_id = isset($_POST['contract_subcon_id']) ? $_POST['contract_subcon_id'] : false;				$user_id = $this->session->userdata('user_id');				$result = array();		$return['valid'] = false;		$return['status_code'] = 501;		$return['message'] = "Internal Server Error";				if(count($_POST) > 0){						if($contract_subcon_id){				$this->rpc_service->setSP("dbo.sp_contract_subcon_delete");				$this->rpc_service->addField('contract_subcon_id',$contract_subcon_id);			}								$result = $this->rpc_service->resultJSON();			// print_r($result);						$data = array();			if(isset($result)){				if(isset($result['valid'])){					if($result['valid']){						if(isset($result['data'])){							$return['valid'] = $result['valid'];							$return['status_code'] = $result['no'];							$return['message'] = $result['des'];						}					} else {						$return['status_code'] = $result['no'];						$return['message'] = $result['des'];					}				}			}					} else {			$return['valid'] = false;			$return['message'] = "Session expired";		}				echo json_encode($return);	}		function post_add_edit(){		$this->authentication->plainlayout();		$parameter = array();		$return = array();						$contract_subcon_id = isset($_POST['contract_subcon_id']) ? $_POST['contract_subcon_id'] : false;		$contract_subcon_no = isset($_POST['contract_subcon_no']) ? $_POST['contract_subcon_no'] : '';		$contract_subcon_date_start = isset($_POST['contract_subcon_date_start']) ? $_POST['contract_subcon_date_start'] : '';		$partner_id = isset($_POST['partner_id']) ? $_POST['partner_id'] : '';		$inv_gl_account_id = isset($_POST['inv_gl_account_id']) ? $_POST['inv_gl_account_id'] : '';		$contract_subcon_type_id = isset($_POST['contract_subcon_type_id']) ? $_POST['contract_subcon_type_id'] : '';				$user_id = $this->session->userdata('user_id');				$result = array();		$return['valid'] = false;		$return['status_code'] = 501;		$return['message'] = "Internal Server Error";				if(count($_POST) > 0){						if($contract_subcon_id){				$this->rpc_service->setSP("dbo.sp_contract_subcon_edit");				$this->rpc_service->addField('contract_subcon_id',$contract_subcon_id);			} else {				$this->rpc_service->setSP("dbo.sp_contract_subcon_add");			}								$this->rpc_service->addField('contract_subcon_no',$contract_subcon_no);			$this->rpc_service->addField('contract_subcon_date_start',$contract_subcon_date_start);			$this->rpc_service->addField('partner_id',$partner_id);			$this->rpc_service->addField('inv_gl_account_id',$inv_gl_account_id);			$this->rpc_service->addField('contract_subcon_type_id',$contract_subcon_type_id);						$result = $this->rpc_service->resultJSON();			// print_r($result);						$data = array();			if(isset($result)){				if(isset($result['valid'])){					if($result['valid']){						if(isset($result['data'])){							$return['valid'] = $result['valid'];							$return['status_code'] = $result['no'];							$return['message'] = $result['des'];						}					} else {						$return['status_code'] = $result['no'];						$return['message'] = $result['des'];					}				}			}					} else {			$return['valid'] = false;			$return['message'] = "Session expired";		}				echo json_encode($return);	}
}?>