<?php if ( ! defined('BASEPATH')) exit('No direct script access allowed');Class Subcon_out extends CI_Controller { 	function __construct(){ 		parent::__construct(); 				$this->data_receive = $_REQUEST;				$module = $this->router->module;		$directory = $this->router->directory;		$class = $this->router->class;		$method = $this->router->method;		$directory = trim(str_replace('../modules/'.$module ,'',str_replace('/controllers/','',$directory)),'/');				$this->module = $module;		if(trim($directory) != ''){			$this->directory = $directory;		} else {			$this->directory = '0';			$this->directory2 = '';		}		$this->class = $class;		$this->method = $method;	}		function subcon_out_table() {		$view = 'view_subcon_out';		$get_field = $this->ecc_library->get_field($view);				$get_field['r1']['hidden'] = true;		$get_field['r15']['hidden'] = true;		$get_field['r16']['hidden'] = true;		$get_field['r17']['hidden'] = true;		$get_field['r18']['hidden'] = true;				return $get_field;	}		function subcon_out_detail_table() {		$view = 'view_subcon_out_detail';		$get_field = $this->ecc_library->get_field($view);				$get_field['r1']['hidden'] = true;		$get_field['r2']['hidden'] = true;				$get_field['r11']['hidden'] = true;		$get_field['r12']['hidden'] = true;		$get_field['r13']['hidden'] = true;				$get_field['act']['sc'] = 'act';		$get_field['act']['title'] = '#';		$get_field['act']['bypassvalue'] = '';		$get_field['act']['ctype'] = 'text';		$get_field['act']['align'] = 'center';		$get_field['act']['search'] = false;		$get_field['act']['sortable'] = false;		$get_field['act']['formatter'] = 'formatOperations';		$get_field['act']['width'] = 300;				return $get_field;	}		function subcon_out_receive_table() {		$view = 'view_stock_move_list_item_subcon_out';		$get_field = $this->ecc_library->get_field($view);				$get_field['r1']['hidden'] = true;		$get_field['r11']['hidden'] = true;		$get_field['r12']['hidden'] = true;		$get_field['r13']['hidden'] = true;				$get_field['r6']['editable'] = true;		$get_field['r7']['editable'] = true;		$get_field['r8']['editable'] = true;		$get_field['r8']['edittype'] = 'select';		$get_field['r8']['formatter'] = 'select';				$array_test = array();		$array_test['value'] = $this->ecc_library->load_uom();				$get_field['r8']['editoptions'] = $array_test;				$get_field['r9']['editable'] = true;		$get_field['r10']['editable'] = true;				$get_field['act']['sc'] = 'act';		$get_field['act']['title'] = '#';		$get_field['act']['bypassvalue'] = '';		$get_field['act']['ctype'] = 'text';		$get_field['act']['align'] = 'center';		$get_field['act']['search'] = false;		$get_field['act']['sortable'] = false;		$get_field['act']['formatter'] = 'formatOperations2';		$get_field['act']['width'] = 300;				return $get_field;	}		function index(){		$this->load->model('main');		$component['loadlayout'] = true;		$component['view_load'] = 'subcon/subcon_out/view';		$component['view_load_form'] = 'subcon/subcon_out/form';		$component['load_js'][] = 'subcon/subcon_out/view';		$component['load_js'][] = 'subcon/subcon_out/form';				$component['page_title'] = "Outgoing Subcon";				$dashboard_table = array();				$nav_button = array();		$nav_button[] = array('method_id' => 480,'title' => 'Add', 'icon' => 'fa fa-plus', 'load' => 'subcon/subcon_out/function_add');		$nav_button[] = array('method_id' => 481,'title' => 'Edit', 'icon' => 'fa fa-pencil', 'load' => 'subcon/subcon_out/function_edit');		$nav_button[] = array('method_id' => 483,'title' => 'Approve', 'icon' => 'fa fa-check', 'load' => 'subcon/subcon_out/function_approve');		$nav_button[] = array('method_id' => 482,'title' => 'Delete', 'icon' => 'fa fa-trash-o', 'load' => 'subcon/subcon_out/function_delete');		$nav_button[] = array('method_id' => 778,'title' => 'Cancel Approve', 'icon' => 'fa fa-check', 'load' => 'subcon/subcon_out/function_cancel_approve');		$nav_button[] = array('method_id' => 841,'title' => 'Print', 'icon' => 'fa fa-print', 'load' => 'subcon/subcon_out/function_print');		$nav_button[] = array('method_id' => 921,'title' => 'Print Subcon Type', 'icon' => 'fa fa-print', 'load' => 'subcon/subcon_out/function_print_subcon_type');				$field = $this->subcon_out_table();		$field_detail = $this->subcon_out_detail_table();		$field_receiver = $this->subcon_out_receive_table();		$dashboard_table['field_detail'] = $field_detail;		$dashboard_table['field_detail_loaddata'] = 'loaddata_detail';		$dashboard_table['field_receiver'] = $field_receiver;		$dashboard_table['field_receiver_loaddata'] = 'loaddata_receive_item';				$dashboard_table['nav_button'] = $nav_button;		$dashboard_table['field'] = $field;				$component['dashboard_table'] = $dashboard_table;				$this->authentication->ajaxlayout($component);	}		function loaddata() {		$this->authentication->plainlayout();				$view = 'view_subcon_out';		$field = $this->subcon_out_table();				$return = array();		$return['valid'] = false;		$return['message'] = "Internal Server Error"; 		$loaddata = $this->ecc_library->get_field_data($view,$field);					echo $loaddata;	}			function approve(){		$this->authentication->plainlayout();		$parameter = array();		$return = array();						$subcon_out_id = isset($_POST['subcon_out_id']) ? $_POST['subcon_out_id'] : false;				$user_id = $this->session->userdata('user_id');				$result = array();		$return['valid'] = false;		$return['status_code'] = 501;		$return['message'] = "Internal Server Error";				if(count($_POST) > 0){						if($subcon_out_id){				$this->rpc_service_portal->setSP("dbo.sp_subcon_out_approve");				$this->rpc_service_portal->addField('subcon_out_id',$subcon_out_id);			}								$result = $this->rpc_service_portal->resultJSON();			// print_r($result);						$data = array();			if(isset($result)){				if(isset($result['valid'])){					if($result['valid']){						if(isset($result['data'])){							$return['valid'] = $result['valid'];							$return['status_code'] = $result['no'];							$return['message'] = $result['des'];						}					} else {						$return['status_code'] = $result['no'];						$return['message'] = $result['des'];					}				}			}					} else {			$return['valid'] = false;			$return['message'] = "Session expired";		}				echo json_encode($return);	}		function cancel_approve(){		$this->authentication->plainlayout();		$parameter = array();		$return = array();						$subcon_out_id = isset($_POST['subcon_out_id']) ? $_POST['subcon_out_id'] : false;				$user_id = $this->session->userdata('user_id');				$result = array();		$return['valid'] = false;		$return['status_code'] = 501;		$return['message'] = "Internal Server Error";				if(count($_POST) > 0){						if($subcon_out_id){				$this->rpc_service_portal->setSP("dbo.sp_subcon_out_cancel_approve");				$this->rpc_service_portal->addField('subcon_out_id',$subcon_out_id);			}								$result = $this->rpc_service_portal->resultJSON();			// print_r($result);						$data = array();			if(isset($result)){				if(isset($result['valid'])){					if($result['valid']){						if(isset($result['data'])){							$return['valid'] = $result['valid'];							$return['status_code'] = $result['no'];							$return['message'] = $result['des'];						}					} else {						$return['status_code'] = $result['no'];						$return['message'] = $result['des'];					}				}			}					} else {			$return['valid'] = false;			$return['message'] = "Session expired";		}				echo json_encode($return);	}		function delete(){		$this->authentication->plainlayout();		$parameter = array();		$return = array();						$subcon_out_id = isset($_POST['subcon_out_id']) ? $_POST['subcon_out_id'] : false;				$user_id = $this->session->userdata('user_id');				$result = array();		$return['valid'] = false;		$return['status_code'] = 501;		$return['message'] = "Internal Server Error";				if(count($_POST) > 0){	