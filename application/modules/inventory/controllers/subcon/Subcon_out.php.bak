is->rpc_service_portal->setSP("dbo.sp_subcon_out_edit");				$this->rpc_service_portal->addField('subcon_out_id',$subcon_out_id);			} else {				$this->rpc_service_portal->setSP("dbo.sp_subcon_out_add");			}											$this->rpc_service_portal->addField('subcon_out_no',$subcon_out_no);			$this->rpc_service_portal->addField('subcon_out_date',$subcon_out_date);			$this->rpc_service_portal->addField('partner_id',$partner_id);			$this->rpc_service_portal->addField('contract_subcon_id',$contract_subcon_id);			$this->rpc_service_portal->addField('subcon_out_memo',$subcon_out_memo);			$this->rpc_service_portal->addField('currencies_id',$currencies_id);						$result = $this->rpc_service_portal->resultJSON();						$data = array();			if(isset($result)){				if(isset($result['valid'])){					if($result['valid']){						if(isset($result['data'])){							$data_result = json_decode($result['data'],true);														$return['valid'] = $result['valid'];							$return['status_code'] = $result['no'];							$return['message'] = $result['des'];							$return['subcon_out_id'] = $data_result['subcon_out_id'];							$return['receiver'] = $data_result['receiver'];							$return['contract_subcon_id'] = $data_result['contract_subcon_id'];						}					} else {						$return['status_code'] = $result['no'];						$return['message'] = $result['des'];					}				}			}					} else {			$return['valid'] = false;			$return['message'] = "Session expired";		}				echo json_encode($return);	}		function loaddata_detail(){		$this->authentication->plainlayout();				$subcon_out_id = isset($_REQUEST['subcon_out_id']) ? is_numeric($_REQUEST['subcon_out_id']) ? $_REQUEST['subcon_out_id']  : -1 : -1;		$methodid = isset($_REQUEST['methodid']) ? is_numeric($_REQUEST['methodid']) ? $_REQUEST['methodid']  : -1 : -1;				$view = 'view_subcon_out_detail';		$field = $this->subcon_out_detail_table();				$return = array();		$return['valid'] = false;		$return['message'] = "Internal Server Error";				$extra_param = array();		$extra_param['where']['0']['field'] = 'r2';		$extra_param['where']['0']['data'] = $subcon_out_id;		$extra_param['methodid'] = $methodid;				$loaddata = $this->ecc_library->get_field_data($view,$field,$extra_param);					echo $loaddata;	}		function post_add_edit_detail(){		$this->authentication->plainlayout();		$parameter = array();		$return = array();				$subcon_out_id = isset($_POST['subcon_out_id']) ? $_POST['subcon_out_id'] : 0;		$subcon_out_detail_id = isset($_POST['subcon_out_detail_id']) ? $_POST['subcon_out_detail_id'] : '';		$item_id = isset($_POST['item_id']) ? $_POST['item_id'] : '';		$quantity_subcon = isset($_POST['quantity_subcon']) ? $_POST['quantity_subcon'] : '';		$uom_id = isset($_POST['uom_id']) ? $_POST['uom_id'] : '';		$conversion = isset($_POST['conversion']) ? $_POST['conversion'] : '';		$unit_price = isset($_POST['unit_price']) ? $_POST['unit_price'] : '';		$subcon_price = isset($_POST['subcon_price']) ? $_POST['subcon_price'] : '';		$user_id = $this->session->userdata('user_id');						$result = array();		$return['valid'] = false;		$return['status_code'] = 501;		$return['message'] = "Internal Server Error";				if(count($_POST) > 0){			if($subcon_out_detail_id){				$this->rpc_service_portal->setSP("dbo.sp_subcon_out_detail_edit");				$this->rpc_service_portal->addField('subcon_out_detail_id',$subcon_out_detail_id);			} else {				$this->rpc_service_portal->setSP("dbo.sp_subcon_out_detail_add");			}						$this->rpc_service_portal->addField('subcon_out_id',$subcon_out_id);			$this->rpc_service_portal->addField('item_id',$item_id);			$this->rpc_service_portal->addField('quantity_subcon',$quantity_subcon);			$this->rpc_service_portal->addField('uom_id',$uom_id);			$this->rpc_service_portal->addField('conversion',$conversion);			$this->rpc_service_portal->addField('unit_price',$unit_price);			$this->rpc_service_portal->addField('subcon_price',$subcon_price);						$result = $this->rpc_service_portal->resultJSON();						$data = array();			if(isset($result)){				if(isset($result['valid'])){					if($result['valid']){						if(isset($result['data'])){							$data = json_decode($result['data'],TRUE);														$return['valid'] = $result['valid'];							$return['status_code'] = $result['no'];							$return['message'] = $result['des'];						}					} else {						$return['status_code'] = $result['no'];						$return['message'] = $result['des'];					}				}			}						} else {			$return['valid'] = false;			$return['message'] = "Session expired";		}				echo json_encode($return);	}		function delete_detail(){		$this->authentication->plainlayout();		$parameter = array();		$return = array();				$result = array();		$return['valid'] = false;		$return['status_code'] = 501;		$return['message'] = "Internal Server Error";				$subcon_out_detail_id = isset($_POST['subcon_out_detail_id']) ? $_POST['subcon_out_detail_id'] : '';		$user_id = $this->session->userdata('user_id');						if(count($_POST) > 0){						if($subcon_out_detail_id){				$this->rpc_service_portal->setSP("dbo.sp_subcon_out_detail_delete");				$this->rpc_service_portal->addField('subcon_out_detail_id',$subcon_out_detail_id);			}								$result = $this->rpc_service_portal->resultJSON();						$data = array();			if(isset($result)){				if(isset($result['valid'])){					if($result['valid']){						if(isset($result['data'])){							$return['valid'] = $result['valid'];							$return['status_code'] = $result['no'];							$return['message'] = $result['des'];						}					} else {						$return['status_code'] = $result['no'];						$return['message'] = $result['des'];					}				}			}					} else {			$return['valid'] = false;			$return['message'] = "Session expired";		}		echo json_encode($return);	}		function loaddata_receive_item(){		$this->authentication->plainlayout();				$contract_subcon_id = isset($_POST['contract_subcon_id']) ? $_POST['contract_subcon_id'] : '';		$subcon_out_detail_id = isset($_POST['subcon_out_detail_id']) ? $_POST['subcon_out_detail_id'] : '';		$methodid = isset($_REQUEST['methodid']) ? is_numeric($_REQUEST['methodid']) ? $_REQUEST['methodid']  : -1 : -1;				$field = $this->subcon_out_receive_table();				$return = array();		$return['valid'] = false;		$return['message'] = "Internal Server Error";				$extra_param = array();		if($subcon_out_detail_id){			$view = 'view_subcon_out_detail_receive';			$extra_param['where']['0']['field'] = 'r13';			$extra_param['where']['0']['data'] = $subcon_out_detail_id;		} else {			$view = 'view_stock_move_list_item_subcon_out';			$extra_param['where']['0']['field'] = 'r12';			$extra_param['where']['0']['data'] = $contract_subcon_id;		}				$extra_param['field']['rh_id'] = $subcon_out_detail_id;				$extra_param['methodid'] = $methodid;				$loaddata = $this->ecc_library->get_field_data($view,$field,$extra_param);					echo $loaddata;	}		function print_subcon_out()   {         $subcon_out_id = isset($_POST['subcon_out_id']) ? $_POST['subcon_out_id'] : false;      $format = isset($_POST['format']) ? $_POST['format'] : 'pdf';      $user_id = $this->session->userdata('user_id');            $sp = "dbo.sp_rpt_subcon_out";       $this->rpc_service_portal->setSP(array("sp"=>$sp,"mode"=>"2","debug"=>"1"));      $this->rpc_service_portal->addField('subcon_out_id',$subcon_out_id);      $this->rpc_service_portal->addField('format',$format);      $this->rpc_service_portal->addField('temp_folder',sys_get_temp_dir());      $this->rpc_service_portal->addField('sort','b.item_code asc');              $result = $this->rpc_service_portal->resultPrint2();      echo json_encode($result);	}		function print_subcon_out_type() {         $subcon_out_id = isset($_POST['subcon_out_id']) ? $_POST['subcon_out_id'] : false;      $format = isset($_POST['format']) ? $_POST['format'] : 'pdf';      $type = isset($_POST['type']) ? $_POST['type'] : false;		      $user_id = $this->session->userdata('user_id');            if($type==1){         $sp = "dbo.sp_rpt_bsgi_kontrak_washing";                        $this->rpc_service_portal->setSP(array("sp"=>$sp,"mode"=>"2","debug"=>"1"));         $this->rpc_service_portal->addField('subcon_out_id',$subcon_out_id);         $this->rpc_service_portal->addField('type',$type);         $this->rpc_service_portal->addField('format',$format);         $this->rpc_service_portal->addField('temp_folder',sys_get_temp_dir());         $this->rpc_service_portal->addField('sort','a.subcon_out_no asc');                    $result = $this->rpc_service_portal->resultPrint2();         echo json_encode($result);      }else{			$sp = "dbo.sp_rpt_bsgi_kontrak_printing";                        $this->rpc_service_portal->setSP(array("sp"=>$sp,"mode"=>"2","debug"=>"1"));         $this->rpc_service_portal->addField('subcon_out_id',$subcon_out_id);         $this->rpc_service_portal->addField('type',$type);         $this->rpc_service_portal->addField('format',$format);         $this->rpc_service_portal->addField('temp_folder',sys_get_temp_dir());         $this->rpc_service_portal->addField('sort','a.subcon_out_no asc');                    $result = $this->rpc_service_portal->resultPrint2();         echo json_encode($result);		}	}}?>