			quantity_supply = parseFloat(unwrap_cell_value(row.r9).replace(/,/g, ''));
			request_supply_id = parseInt(unwrap_cell_value(row.r3).replace(/,/g, ''));
			quantity_supply = parseFloat(unwrap_cell_value(row.r9).replace(/,/g, ''));
			
			var row_available = $("#table_<?php echo $methodid ?>_available").jqGrid('getRowData',id);
