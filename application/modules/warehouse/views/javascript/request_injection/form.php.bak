	function supply_<?php echo $methodid?>(id){
		$.ajax({
			url: baseurl+'loader',
			data: {
				'<?php echo $this->security->get_csrf_token_name() ?>':'<?php echo $this->security->get_csrf_hash() ?>'
				,param: 'data_request_injection'
				,id : id
			},
			dataType: 'json',
			method: 'post',
			success: function(data){
				request_id = data[0].request_id;
				
				$('#form_<?php echo $methodid ?>_supply_request_id').val(request_id);
				$('#form_<?php echo $methodid ?>_supply_request_detail_id').val('');
				$('#form_<?php echo $methodid ?>_supply_request_no').val(data[0].request_no);
				$('#form_<?php echo $methodid ?>_supply_request_date').val(data[0].request_date);
				$('#form_<?php echo $methodid ?>_supply_info').val(data[0].info);
				
				setTimeout(function(){ 
					$("#table_<?php echo $methodid ?>_supply").trigger('reloadGrid');
					$("#table_<?php echo $methodid ?>_supply").setGridWidth($('.grid_container_<?php echo $methodid; ?>_supply').width() - 20,true).trigger('resize');
					
					$("#table_<?php echo $methodid ?>_available").trigger('reloadGrid');
