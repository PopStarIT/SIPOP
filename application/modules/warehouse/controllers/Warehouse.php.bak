<?php if ( ! defined('BASEPATH')) exit('No direct script access allowed');Class Warehouse extends CI_Controller { 	function __construct(){ 		parent::__construct(); 	} 		function index(){		$component['loadlayout'] = true;		$component['view_load'] = 'warehouse';				$dashboard_tab = array();				$tab_utama = array('alias' => 'warehouse_utama', 'title' => 'Warehouse 1', 'icon' => 'fa fa-cog');		$tab_injection = array('alias' => 'warehouse_injection', 'title' => 'Warehouse 2', 'icon' => 'fa fa-cog');		$tab_report = array('alias' => 'warehouse_report', 'title' => 'Report', 'icon' => 'fa fa-cog');				$tab_utama_content = array();		$tab_utama_content[] = array('method_id' => 50034, 'menu_name' => 'Transfer Warehouse 1', 'menu_icon' => 'fa fa-external-link');		$tab_utama_content[] = array('method_id' => 50153, 'menu_name' => 'Monitoring Stock Warehouse 1', 'menu_icon' => 'fa fa-book fa-fw');		$tab_utama['content'] = $tab_utama_content;				$tab_injection_content = array();		$tab_injection_content[] = array('method_id' => 50016, 'menu_name' => 'Request Warehouse 2', 'menu_icon' => 'fa fa-cog');		$tab_injection_content[] = array('method_id' => 50090, 'menu_name' => 'Return Warehouse 2', 'menu_icon' => 'fa fa-external-link');		$tab_injection_content[] = array('method_id' => 50149, 'menu_name' => 'Monitoring Stock Warehouse 2', 'menu_icon' => 'fa fa-book fa-fw');		$tab_injection['content'] = $tab_injection_content;				$tab_report_content = array();		$tab_report_content[] = array('method_id' => 50002, 'menu_name' => 'Mutasi Bahan Baku Warehouse 1', 'menu_icon' => 'fa fa-file-text-o');		$tab_report_content[] = array('method_id' => 58018, 'menu_name' => 'Mutasi Bahan Baku Warehouse 2', 'menu_icon' => 'fa fa-file-text-o');		$tab_report_content[] = array('method_id' => 50004, 'menu_name' => 'Mutasi Barang Jadi Warehouse 1', 'menu_icon' => 'fa fa-file-text-o');		$tab_report_content[] = array('method_id' => 58022, 'menu_name' => 'Mutasi Barang Jadi Warehouse 2', 'menu_icon' => 'fa fa-file-text-o');		$tab_report_content[] = array('method_id' => 58025, 'menu_name' => 'Pengeluaran warehouse 1 Ke Warehouse 2', 'menu_icon' => 'fa fa-file-text-o');		$tab_report_content[] = array('method_id' => 58025, 'menu_name' => 'Return warehouse 2 Ke Warehouse 1', 'menu_icon' => 'fa fa-file-text-o');		$tab_report['content'] = $tab_report_content;								$dashboard_tab[] = $tab_utama;		$dashboard_tab[] = $tab_injection;										$dashboard_tab[] = $tab_report;						$component['dashboard_tab'] = $dashboard_tab;						$this->authentication->ajaxlayout($component);	}}?>