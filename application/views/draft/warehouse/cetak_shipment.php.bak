    <style>
        /* Gaya Tampilan di Layar (Screen) */
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f4f4;
            margin: 0;
            padding: 10px;
        }
